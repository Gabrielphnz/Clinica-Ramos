// ==========================================
var pacienteAtualProntuario = null;

function abrirProntuario(nomePaciente) {
  if (!nomePaciente) return;
  const busca = nomePaciente.toString().trim().toLowerCase();
  const paciente = basePacientesCRM.find(p => (p && p.nome) ? p.nome.toString().trim().toLowerCase() === busca : false);

  if (!paciente) return mostrarNotificacao("Paciente incompleto ou não localizado.", "erro");
  pacienteAtualProntuario = paciente;

  document.getElementById("prontuarioNomeHeader").innerText = paciente.nome || "Sem Nome";
  document.getElementById("prontuarioNomeLateral").innerText = paciente.nome || "Sem Nome";
  document.getElementById("prontuarioConvenio").innerText = paciente.convenio || "Particular";

  const iniciais = (paciente.nome || "SN").split(' ').filter(x=>x).map(n=>n[0]).join('').substring(0, 2).toUpperCase();
  document.getElementById("prontuarioIniciais").innerText = iniciais;

  // Preenchedor Múltiplo (Tenta vários IDs possíveis do HTML)
  const preencherVisor = (ids, valor) => {
      for(let id of ids) {
          const el = document.getElementById(id);
          if (el) { el.value = valor || ""; return; }
      }
  };

  preencherVisor(["ficha_nome"], paciente.nome);
  preencherVisor(["ficha_cpf"], paciente.cpf);
  preencherVisor(["ficha_rg"], paciente.rg);
  preencherVisor(["ficha_nascimento"], paciente.nascimento);
  preencherVisor(["ficha_celular"], paciente.celular);
  preencherVisor(["ficha_telefone", "ficha_telefonefixo", "telefonefixo", "ficha_telefonerecado"], paciente.telefone);
  preencherVisor(["ficha_email"], paciente.email);
  preencherVisor(["ficha_convenio", "ficha_plano"], paciente.convenio);
  preencherVisor(["ficha_endereco"], paciente.endereco);
  preencherVisor(["ficha_responsavel", "ficha_resp"], paciente.responsavel);

  // Cálculo de Idade Imbatível
  let dtNasc = null;
  const nasc = (paciente.nascimento || "").toString();
  if (nasc.includes('/')) {
      let p = nasc.split('/'); dtNasc = new Date(p[2], p[1]-1, p[0]);
  } else if (nasc.includes('-')) {
      let p = nasc.split('-'); dtNasc = new Date(p[0], p[1]-1, p[2]);
  }

  if (dtNasc && !isNaN(dtNasc)) {
      let idade = new Date().getFullYear() - dtNasc.getFullYear();
      const m = new Date().getMonth() - dtNasc.getMonth();
      if (m < 0 || (m === 0 && new Date().getDate() < dtNasc.getDate())) idade--;
      preencherVisor(["ficha_idade", "idade"], (idade >= 0 ? idade + " anos" : "--"));
  } else {
      preencherVisor(["ficha_idade", "idade"], "--");
  }

  // Carrega painéis inferiores
  carregarHistoricoFinanceiroFicha(paciente.nome);
  carregarAnamneseCompleta(); 
  carregarOdontograma(paciente.nome);
  carregarEvolucao(paciente.nome);
  carregarHistoricoDocumentos(paciente.nome);

  const modalElem = document.getElementById('modalProntuario');
  if (modalElem) bootstrap.Modal.getOrCreateInstance(modalElem).show();
  
  setTimeout(() => {
    const btn = document.querySelector('[data-bs-target="#tabFicha"]');
    if(btn) bootstrap.Tab.getOrCreateInstance(btn).show();
  }, 250);
}

