  // Gera um Hash de Autenticidade único (Ex: AUTH-8F2A-9B1C)
  const hashAutenticidade = "AUTH-" + Math.random().toString(36).substr(2, 4).toUpperCase() + "-" + Date.now().toString(36).substr(4, 4).toUpperCase();

  // Layout Base (Com proteção contra quebra de página na assinatura)
  const layoutBase = (titulo, label, conteudo, assinaturaCustomizada = null) => {
    const signHtml = assinaturaCustomizada || `
      <div class="signature" style="page-break-inside: avoid;">
        <div class="line"></div>
        <strong>${nomeDoutor}</strong><br><small>${croDoutor}</small>
