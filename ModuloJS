var pacienteAtualProntuario = null;

function abrirProntuario(nomePaciente) {
  // 1. Acha o paciente no CRM
  const paciente = basePacientesCRM.find(p => p.nome.toLowerCase() === nomePaciente.toLowerCase());
  if (!paciente) return mostrarNotificacao("Paciente não encontrado no CRM!", "erro");
  
  pacienteAtualProntuario = paciente;

  // 2. Preenche a barra lateral
  document.getElementById("prontuarioNomeHeader").innerText = paciente.nome;
  document.getElementById("prontuarioNomeLateral").innerText = paciente.nome;
  document.getElementById("prontuarioConvenio").innerText = paciente.convenio || "Particular";
  
  const iniciais = paciente.nome.split(' ').map(n => n[0]).join('').substring(0,2).toUpperCase();
  document.getElementById("prontuarioIniciais").innerText = iniciais;

  // 3. Preenche a Aba "Ficha Pessoal" COMPLETA
  document.getElementById("ficha_nome").value = paciente.nome || '';
  document.getElementById("ficha_cpf").value = paciente.cpf || '';
  document.getElementById("ficha_rg").value = paciente.rg || '';
  document.getElementById("ficha_nascimento").value = paciente.nascimento || '';
  document.getElementById("ficha_celular").value = paciente.celular || '';
  document.getElementById("ficha_telefone").value = paciente.telefone || '';
  document.getElementById("ficha_email").value = paciente.email || '';
  document.getElementById("ficha_convenio").value = paciente.convenio || 'Particular';
  document.getElementById("ficha_endereco").value = paciente.endereco || '';
  document.getElementById("ficha_responsavel").value = paciente.responsavel || '';

  // 4. Calcula a Idade automaticamente
  if (paciente.nascimento && paciente.nascimento.length >= 8) {
    try {
      const [dia, mes, ano] = paciente.nascimento.split('/');
      const dataNasc = new Date(ano, mes - 1, dia);
      const hoje = new Date();
      let idade = hoje.getFullYear() - dataNasc.getFullYear();
      const m = hoje.getMonth() - dataNasc.getMonth();
      if (m < 0 || (m === 0 && hoje.getDate() < dataNasc.getDate())) { idade--; }
      document.getElementById("ficha_idade").value = idade + " anos";
    } catch(e) { document.getElementById("ficha_idade").value = ""; }
  } else {
    document.getElementById("ficha_idade").value = "";
  }

  // 5. Ativa as novas funções
  if(typeof setupAnamneseToggles === "function") setupAnamneseToggles();
  if(typeof carregarFiltroDoutores === "function") carregarFiltroDoutores();
  
  // 6. Carrega Históricos e Dados
  carregarHistoricoFinanceiroFicha(paciente.nome); // Nova chamada que arruma os totais!
  carregarAnamneseCompleta();
  carregarOdontograma(paciente.nome);
  carregarEvolucao(paciente.nome);

  // 7. Abre o modal e foca na aba Evolução
  new bootstrap.Modal(document.getElementById('modalProntuario')).show();
  var triggerEl = document.querySelector('#tabsProntuario button[data-bs-target="#tabEvolucao"]');
  if(triggerEl) {
      bootstrap.Tab.getInstance(triggerEl)?.show() || new bootstrap.Tab(triggerEl).show();
  }
}

function carregarHistoricoFinanceiroFicha(nome) {
  const corpo = document.getElementById("ficha_tabela_procedimentos");
  if (!corpo) return;

  // Filtra todos os lançamentos financeiros desse paciente
  const historico = dadosLocais.filter(r => r.paciente.toLowerCase() === nome.toLowerCase());

  if (historico.length === 0) {
    corpo.innerHTML = '<tr><td colspan="4" class="text-center py-4 text-muted">Nenhum procedimento lançado.</td></tr>';
    document.getElementById("prontuarioTotalAtendimentos").innerText = "0";
    document.getElementById("prontuarioTotalGasto").innerText = "R$ 0,00";
    document.getElementById("prontuarioUltimaConsulta").innerText = "--/--/----";
    return;
  }

  // 1. Monta a tabela
  let htmlProcs = '';
  let totalGasto = 0;
  
  historico.forEach(p => {
    let valorTotal = (Number(p.particular) || 0) + (Number(p.vplano) || 0);
    totalGasto += valorTotal;
    
    htmlProcs += '<tr>' +
      '<td class="ps-4 fw-bold">' + p.data + '</td>' +
      '<td><span class="badge bg-light text-primary border px-2 py-1">' + p.procedimento + '</span></td>' +
      '<td class="text-muted"><span class="material-icons align-middle text-muted" style="font-size:14px">person</span> ' + p.doutor + '</td>' +
      '<td class="text-success fw-bold text-end pe-4">R$ ' + valorTotal.toFixed(2).replace('.',',') + '</td>' +
    '</tr>';
  });
  corpo.innerHTML = htmlProcs;

  // 2. Atualiza os Totais da Barra Lateral
  document.getElementById("prontuarioTotalAtendimentos").innerText = historico.length;
  document.getElementById("prontuarioTotalGasto").innerText = "R$ " + totalGasto.toLocaleString('pt-BR', {minimumFractionDigits: 2});

  // 3. Descobre a data mais recente
  const datasOrd = [...historico].filter(r => r.data && r.data.includes('/')).sort((a, b) => {
      const [dA, mA, aA] = a.data.split('/');
      const [dB, mB, aB] = b.data.split('/');
      return new Date(aB, mB-1, dB) - new Date(aA, mA-1, dA);
  });
  
  if (datasOrd.length > 0) {
      document.getElementById("prontuarioUltimaConsulta").innerText = datasOrd[0].data;
  }
}

