window.abrirAbaGestor = function() {
    // 1. Remove o 'active' de todos os botões das abas principais
    document.querySelectorAll('#docsTabs .nav-link').forEach(btn => {
        btn.classList.remove('active', 'bg-primary', 'text-white');
        btn.classList.add('bg-white', 'text-secondary');
    });

    // 2. Esconde todas as telas (panes) do tab-content
    document.querySelectorAll('#modalGeradorDoc .tab-pane').forEach(tela => {
        tela.classList.remove('show', 'active');
    });

    // 3. Mostra apenas a tela do Gestor
    const telaGestor = document.getElementById('tabGestor');
    if (telaGestor) {
        telaGestor.classList.add('show', 'active');
    }

    // 4. Dá destaque visual ao botão de Ajustes (opcional)
    const btnAjustes = event.target.closest('button');
    if (btnAjustes) btnAjustes.classList.add('bg-primary', 'text-white');

    if (typeof window.renderizarGestor === 'function') {
        window.renderizarGestor();
    }
};

