  container.appendChild(div);
}

// Nova função: Escuta o teclado e adiciona linha nova
function checarEnterLote(event, tipo) {
  if (event.key === 'Enter') {
    event.preventDefault(); // Evita que o formulário recarregue a página
    adicionarLinhaLote(tipo); // Cria a linha nova

    // Foca automaticamente no campo "Produto" da linha que acabou de ser criada
    setTimeout(() => {
      const linhas = document.querySelectorAll('.linha-lote');
      const ultimaLinha = linhas[linhas.length - 1];
      if (ultimaLinha) {
        ultimaLinha.querySelector('.input-produto').focus();
      }
    }, 50);
  }
}
function tratarIndexador(input) {
  let valor = input.value.trim();
  if (!valor) return;
  
  let p = null;
  // Se digitou só o ID (ex: "1")
  if (!isNaN(valor)) {
    p = estoqueCompletoCache.find(x => x.id == valor);
    if (p) input.value = `${p.id} - ${p.nome}`;
  } else {
    // Se selecionou na lista suspensa (ex: "1 - Resina")
    let match = valor.match(/^(\d+)\s+-\s+(.+)$/);
    if (match) {
        p = estoqueCompletoCache.find(x => x.id == match[1]);
    }
  }

  // Preenche a categoria automaticamente se achou o produto
  if (p) {
    let linha = input.closest('.linha-lote');
    if(linha.querySelector('.input-categoria')) {
        linha.querySelector('.input-categoria').value = p.categoria;
    }
  }
}

function salvarLoteGenerico(tipo) {
  const btn = document.getElementById('btnSalvarLote');
  const linhas = document.querySelectorAll('.linha-lote');
  if (linhas.length === 0) return;
  
  btn.disabled = true; 
  btn.innerText = "Processando...";
  let lote = [];
  
  linhas.forEach(linha => {
    let valorStr = linha.querySelector('.input-valor')?.value || "0";
    
    // CORREÇÃO: Limpa o "ID - " do nome do produto antes de salvar
    let produtoBruto = linha.querySelector('.input-produto').value.trim();
    let nomeProdutoFinal = produtoBruto;
    
    // Se tiver o formato "Numero - Nome", extrai só o Nome
    let matchProd = produtoBruto.match(/^(\d+)\s+-\s+(.+)$/);
    if (matchProd) {
        nomeProdutoFinal = matchProd[2]; // Pega só o texto depois do " - "
    } else if (!isNaN(produtoBruto)) {
        // Se o usuário digitou só o número do ID e já clicou em salvar
        let p = estoqueCompletoCache.find(x => x.id == produtoBruto);
        if (p) nomeProdutoFinal = p.nome;
    }

    lote.push({
      usuarioLogado: usuarioLogado.nome,
      produto: nomeProdutoFinal, // Agora envia o nome exato para bater a matemática!
      categoria: linha.querySelector('.input-categoria')?.value || "",
      quantidade: linha.querySelector('.input-qtd').value,
      custoTotal: Number(valorStr.replace(/\./g, '').replace(',', '.')) || 0,
      doutor: linha.querySelector('.input-doutor')?.value || "",
      obs: linha.querySelector('.input-obs').value
    });
  });
  
  google.script.run.withSuccessHandler(res => { 
    mostrarNotificacao(res, "sucesso"); 
    bootstrap.Modal.getInstance(document.getElementById('modalLoteGenerico')).hide(); 
    abrirAlmoxarifado(); 
  }).salvarMovimentoEstoqueLote(lote, tipo);
}

