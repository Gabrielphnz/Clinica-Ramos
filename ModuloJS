// --- FUNÇÕES AUXILIARES INTELIGENTES ---

function atualizarEstatisticasLateral(ultima, atendimentos, valorGasto) {
  const valorFormatado = valorGasto.toLocaleString('pt-BR', {style: 'currency', currency: 'BRL'});
  
  const preencher = (ids, valor) => {
      for (let id of ids) {
          const el = document.getElementById(id);
          if (el) { 
             if(el.tagName === 'INPUT') el.value = valor;
             else el.innerText = valor; 
             return true; 
          }
      }
      return false;
  };

  preencher(["prontuarioUltimaConsulta", "ficha_ultima_consulta", "txtUltimaConsulta"], ultima);
  preencher(["prontuarioTotalAtendimentos", "ficha_total_atendimentos", "txtTotalAtendimentos"], atendimentos);
  
  const achouValor = preencher(["prontuarioValorGasto", "ficha_valor_gasto", "txtValorGasto"], valorFormatado);

  // 🎯 CAÇADOR DE TEXTO (Caso os IDs acima falhem, ele acha o "R$ 0,00" visualmente e troca)
  if (!achouValor) {
     const elementos = document.querySelectorAll('span, b, strong, p');
     for (let el of elementos) {
         if (el.innerText && el.innerText.trim() === 'R$ 0,00') {
             // Garante que só vai trocar o R$ 0,00 verde da lateral
             if (el.classList.contains('text-success') || el.closest('div').innerText.includes('Valor total gasto')) {
                 el.innerText = valorFormatado;
                 break;
             }
         }
     }
  }
}

function injetarLinhasHistorico(html) {
  let tbody = document.getElementById("tabelaHistoricoProcedimentos") || 
              document.getElementById("tabelaFinanceiroFicha") || 
              document.getElementById("corpoHistoricoProcedimentos");
  
  // Caçador de tabela pelo texto "Carregando..."
  if (!tbody) {
