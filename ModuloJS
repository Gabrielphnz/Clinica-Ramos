function marcarStatusDente(status) {
  if (!pacienteAtualProntuario || !denteAtivo) return;
  
  const denteEl = document.getElementById('dente_' + denteAtivo);
  
  // Remove cores antigas
  denteEl.classList.remove('problema', 'feito', 'ausente');
  
  if (status !== 'limpar') {
    denteEl.classList.add(status);
  }

  // Fecha o mini modal
  bootstrap.Modal.getInstance(document.getElementById('modalAcaoDente')).hide();

  // Salva no Banco de Dados silenciosamente
  google.script.run.salvarEstadoDente(pacienteAtualProntuario.nome, denteAtivo, status);
  mostrarNotificacao("Dente " + denteAtivo + " atualizado!", "sucesso");
}

// Função para carregar o odontograma salvo ao abrir o prontuário
function carregarOdontograma(nomePaciente) {
  // Limpa o visual antes de carregar
  document.querySelectorAll('.dente-box').forEach(el => el.classList.remove('problema', 'feito', 'ausente'));

  google.script.run.withSuccessHandler(function(dadosSalvos) {
