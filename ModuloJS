    return `
    <div class="page ${tipo === 'RECEITA' && label.includes('1ª') ? 'page-break' : ''}">
      <div class="header">
        <p class="logo">${nomeDoutor.toUpperCase()}</p>
        <small>${croDoutor} | ODONTOLOGIA ESPECIALIZADA</small>
      </div>
      <div class="title">${titulo} ${label ? '<br><small style="color:#A3AED0; font-size:12px;">'+label+'</small>' : ''}</div>
