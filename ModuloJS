function editarRegistro(idLinha) {
  const r = dadosLocais.find(item => item.id == idLinha);
  if (!r) return;

  const [dia, mes, ano] = r.data.split('/');
  const dataLanc = new Date(ano, mes - 1, dia);
  const hoje = new Date();
  hoje.setHours(0,0,0,0);
  
  const diffDays = (hoje - dataLanc) / (1000 * 60 * 60 * 24);

  if (diffDays > 1 && usuarioLogado.nivel !== "ADMIN") {
    mostrarNotificacao("🚫 Bloqueado: Apenas o Administrador pode editar registros retroativos.", "erro");
    return;
  }

  const form = document.getElementById("formCadastro");
  document.getElementById("idLinha").value = r.id; 
  document.getElementById("btnExcluir").style.display = "block"; 
  document.getElementById("autocomplete-list").style.display = "none";
  
  form.data.value = r.data;
  form.paciente.value = r.paciente; 
  form.doutor.value = r.doutor;
  form.procedimento.value = r.procedimento; 
  form.plano.value = r.plano; 
  form.pagamento.value = r.pagamento; 
  form.obs.value = r.obs;
  
  const converteMoeda = (val) => Number(val).toLocaleString('pt-BR', {minimumFractionDigits: 2, maximumFractionDigits: 2});
  form.particular.value = converteMoeda(r.particular); 
  form.vplano.value = converteMoeda(r.vplano); 
  form.vlab.value = converteMoeda(r.vlab);
  
  new bootstrap.Modal(document.getElementById('modalCadastro')).show();
}

