function salvarPacienteCRM() {
  const form = document.getElementById("formPacienteCompleto");
  if (!form.checkValidity()) { form.reportValidity(); return; }

  const btn = event.target;
  btn.disabled = true; btn.innerText = "PROCESSANDO...";

  const dadosRaw = {};
  new FormData(form).forEach((value, key) => { dadosRaw[key] = value; });

  const nomeOriginal = dadosRaw.nome_original ? dadosRaw.nome_original.trim() : "";
  const ehEdicao = nomeOriginal !== "";

  // Caçador de dados do formulário (Ignora IDs ou Names errados)
  const extrair = (palavrasChave) => {
      for (let k of Object.keys(dadosRaw)) {
          const kLimpa = k.normalize("NFD").replace(/[\u0300-\u036f]/g, "").toLowerCase();
          if (palavrasChave.some(p => kLimpa.includes(p))) return dadosRaw[k];
      }
      return "";
  };

  // Monta o pacote EXATO que o backend espera
  const payloadBackend = {
      Nome: extrair(["nome"]),
      CPF: extrair(["cpf"]),
      RG: extrair(["rg", "identidade"]),
      Nascimento: extrair(["nascimento", "nasc"]),
      Celular: extrair(["celular", "whats"]),
      Telefone: extrair(["telefone", "fixo", "recado"]),
      Email: extrair(["email", "mail"]),
      sexo: extrair(["sexo", "genero"]),
      profissao: extrair(["profissao", "prof"]),
      convenio: extrair(["convenio", "plano"]),
      Endereco: extrair(["endereco", "end"]),
      Responsavel: extrair(["responsavel", "menor", "resp"]),
      nome_original: nomeOriginal
  };

  mostrarNotificacao("⏳ Salvando dados...", "info");

  google.script.run
    .withSuccessHandler(function(res) {
      mostrarNotificacao("✅ " + res, "sucesso");
      
      // Fecha modal de edição
      const m = bootstrap.Modal.getInstance(document.getElementById('modalPaciente'));
      if(m) m.hide();

      // INJEÇÃO INSTANTÂNEA NA MEMÓRIA (Acaba com a necessidade de F5)
      const pNovo = {
        nome: payloadBackend.Nome, cpf: payloadBackend.CPF, rg: payloadBackend.RG, 
        nascimento: payloadBackend.Nascimento, celular: payloadBackend.Celular, 
        telefone: payloadBackend.Telefone, email: payloadBackend.Email, 
        sexo: payloadBackend.sexo, profissao: payloadBackend.profissao, 
        convenio: payloadBackend.convenio, endereco: payloadBackend.Endereco, 
        responsavel: payloadBackend.Responsavel
      };

      if (ehEdicao) {
        const idx = basePacientesCRM.findIndex(p => p.nome.toLowerCase() === nomeOriginal.toLowerCase());
        if (idx !== -1) basePacientesCRM[idx] = pNovo;
      } else {
        basePacientesCRM.push(pNovo);
      }

      // REPINTA O PRONTUÁRIO NA HORA!
      abrirProntuario(payloadBackend.Nome);
      
      btn.disabled = false; btn.innerText = "💾 SALVAR PACIENTE";
    })
    .withFailureHandler(function(err) {
      mostrarNotificacao("❌ Erro: " + err, "erro");
      btn.disabled = false; btn.innerText = "💾 SALVAR PACIENTE";
    })
    .cadastrarPacienteNoCRM(payloadBackend);
}




