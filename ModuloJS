function carregarRegrasNaTabela() {
  document.getElementById("tabelaConfigRegras").innerHTML = '<tr><td class="text-center">Carregando...</td></tr>';
  google.script.run.withSuccessHandler(function(regras) {
    const tbody = document.getElementById("tabelaConfigRegras");
    if(regras.length === 0) { tbody.innerHTML = '<tr><td class="text-center text-muted small">Nenhuma regra criada.</td></tr>'; return; }
    tbody.innerHTML = regras.map(r => `<tr><td class="fw-bold text-dark">${r.proc}</td><td class="text-center"><span class="badge bg-light text-dark border">${r.dias} dias</span></td><td class="text-end"><button class="btn btn-sm btn-outline-danger border-0" onclick="excluirRegra('${r.proc}')"><span class="material-icons" style="font-size: 16px;">delete</span></button></td></tr>`).join('');
  }).apiRegrasRecorrencia("LER");
}
function salvarRegra() {
  const proc = document.getElementById("cfg_proc").value.trim(); const dias = document.getElementById("cfg_dias").value;
  if(!proc || !dias) return alert("Preencha procedimento e dias!");
  document.getElementById("cfg_proc").value = ""; document.getElementById("cfg_dias").value = "";
  document.getElementById("tabelaConfigRegras").innerHTML = '<tr><td class="text-center">Salvando...</td></tr>';
  google.script.run.withSuccessHandler(function() { carregarRegrasNaTabela(); carregarPainelRetornos(); }).apiRegrasRecorrencia("SALVAR", proc, dias);
}
function excluirRegra(proc) {
  if(!confirm("Excluir a regra para: " + proc + "?")) return;
  document.getElementById("tabelaConfigRegras").innerHTML = '<tr><td class="text-center">Excluindo...</td></tr>';
  google.script.run.withSuccessHandler(function() { carregarRegrasNaTabela(); carregarPainelRetornos(); }).apiRegrasRecorrencia("EXCLUIR", proc);
}


