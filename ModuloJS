function importarPedidoEstoque() {
    let idInput = prompt("Digite ou cole o ID do Pedido (Ex: ORD-17384...):");
    if (!idInput) return;
    
    let id = idInput.trim();
    let historico = JSON.parse(localStorage.getItem('ramos_pedidos_salvos') || '{}');
    let pedido = historico[id];
    
    if (!pedido) {
        return mostrarNotificacao("❌ Pedido não encontrado no histórico. Verifique o ID.", "erro");
    }

    // Abre o formulário de Entrada vazio
    formLoteGenerico('ENTRADA');
    
    setTimeout(() => {
        // Limpa a linha em branco inicial
        document.getElementById('containerLinhasLote').innerHTML = '';
        
        // Insere as linhas do pedido salvo
        pedido.itens.forEach((item, index) => {
            setTimeout(() => {
                adicionarLinhaLote('ENTRADA');
                const linhas = document.querySelectorAll('.linha-lote');
                const ultimaLinha = linhas[linhas.length - 1];
                
                // Preenche os dados
                ultimaLinha.querySelector('.input-produto').value = item.produto;
                ultimaLinha.querySelector('.input-qtd').value = item.qtd;
                ultimaLinha.querySelector('.input-valor').value = item.subtotal;
                ultimaLinha.querySelector('.input-obs').value = "Ref: " + id;
                
                // Força o sistema a achar o ID/Categoria do produto
                tratarIndexador(ultimaLinha.querySelector('.input-produto'));
            }, index * 100); // Pequeno delay pra dar tempo do DOM renderizar cada linha
        });
        mostrarNotificacao("✅ Itens importados com sucesso! Revise e clique em Salvar.", "sucesso");
    }, 500);
}

function executarComPDF(callback) {
    if (window.jspdf || window.jsPDF) {
        return callback(window.jspdf ? window.jspdf.jsPDF : window.jsPDF);
    }
    mostrarNotificacao("Baixando motor de PDF, aguarde um instante...", "info");
    const script1 = document.createElement('script');
    script1.src = "https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js";
    script1.onload = () => {
        const script2 = document.createElement('script');
        script2.src = "https://cdnjs.cloudflare.com/ajax/libs/jspdf-autotable/3.5.28/jspdf.plugin.autotable.min.js";
        script2.onload = () => { callback(window.jspdf.jsPDF); };
        document.head.appendChild(script2);
    };
    document.head.appendChild(script1);
}

