let itensOrcamentoAtuais = [];

function puxarPrecoOrcamento(procDigitado) {
    if (!tabelaPrecosGlobal) return;
    const item = tabelaPrecosGlobal.find(p => p.proc.toUpperCase() === procDigitado.toUpperCase());
    if (item && item.preco) {
        document.getElementById('docOrcValor').value = Number(item.preco).toLocaleString('pt-BR', {minimumFractionDigits: 2});
    }
}

function addLinhaOrcamento() {
    const proc = document.getElementById('docOrcProc').value;
    const valor = document.getElementById('docOrcValor').value;
    if (!proc || !valor) return;
    
    itensOrcamentoAtuais.push({ proc: proc, valor: valor });
    document.getElementById('docOrcProc').value = ''; document.getElementById('docOrcValor').value = '';
    renderizarTabelaOrcamento();
}

function removerLinhaOrcamento(index) {
    itensOrcamentoAtuais.splice(index, 1);
    renderizarTabelaOrcamento();
}

function renderizarTabelaOrcamento() {
    const tbody = document.getElementById('tabelaItensOrcamento');
    let total = 0;
    tbody.innerHTML = itensOrcamentoAtuais.map((item, index) => {
        total += parseFloat(item.valor.replace(/\./g, '').replace(',', '.'));
        return `<tr><td class="fw-bold">${item.proc}</td><td class="text-end text-success">R$ ${item.valor}</td><td class="text-center"><span class="material-icons text-danger" style="font-size:16px; cursor:pointer;" onclick="removerLinhaOrcamento(${index})">delete</span></td></tr>`;
    }).join('');
    document.getElementById('docOrcTotal').innerText = `R$ ${total.toLocaleString('pt-BR', {minimumFractionDigits: 2})}`;
}

