function salvarAnamneseCompleta() {
  if (!pacienteAtualProntuario) {
    mostrarNotificacao("❌ Nenhum paciente selecionado!", "erro");
    return;
  }
  
  // Captura todos os campos que começam com 'ana_' automaticamente
  const inputs = document.querySelectorAll('[id^="ana_"]');
  const dados = {};
  
  inputs.forEach(el => {
    if (el.type === 'checkbox') {
      dados[el.id] = el.checked;
    } else if (el.type === 'radio') {
      if (el.checked) dados[el.id] = el.value;
    } else {
      dados[el.id] = el.value;
    }
  });

  // Adiciona metadados
  dados.data_salvamento = new Date().toISOString();
  dados.salvo_por = usuarioLogado?.nome || '';

  mostrarNotificacao("⏳ Salvando anamnese...", "info");
  
  google.script.run
    .withSuccessHandler(function(res) {
      mostrarNotificacao("✅ Anamnese salva com sucesso!", "sucesso");
      console.log("Anamnese salva:", Object.keys(dados).length, "campos");
    })
    .withFailureHandler(function(err) {
      console.error("Erro ao salvar:", err);
      mostrarNotificacao("❌ Erro ao salvar anamnese!", "erro");
    })
    .salvarDadosAnamnese(pacienteAtualProntuario.nome, JSON.stringify(dados));
}

// ==========================================
// CARREGAR ANAMNESE SALVA
// ==========================================
function carregarAnamneseCompleta() {
  const paciente = pacienteAtualProntuario;
  if (!paciente) return;
  
  // Preencher identificação básica
  document.getElementById('ana_nome').value = paciente.nome || '';
  document.getElementById('ana_nascimento').value = paciente.nascimento || '';
  document.getElementById('ana_sexo').value = paciente.sexo || '';
  document.getElementById('ana_estado_civil').value = paciente.estado_civil || '';
  document.getElementById('ana_profissao').value = paciente.profissao || '';
  
  // Calcular idade se tiver nascimento
  if (paciente.nascimento) {
    let nascParts = [];
    if (paciente.nascimento.includes('/')) {
        nascParts = paciente.nascimento.split('/');
        nascParts = [nascParts[2], nascParts[1], nascParts[0]]; // Converte para YYYY, MM, DD
    } else if (paciente.nascimento.includes('-')) {
        nascParts = paciente.nascimento.split('-');
    }
    
    if (nascParts.length === 3) {
        const nasc = new Date(nascParts[0], nascParts[1] - 1, nascParts[2]);
        const hoje = new Date();
        let idade = hoje.getFullYear() - nasc.getFullYear();
        const m = hoje.getMonth() - nasc.getMonth();
        if (m < 0 || (m === 0 && hoje.getDate() < nasc.getDate())) idade--;
        document.getElementById('ana_idade').value = idade;
    }
  }
  
  // Busca os dados completos no Servidor
  carregarDadosAnamnese(paciente.nome);
}

// ==========================================
// FUNÇÃO PARA CARREGAR ANAMNESE (OTIMIZADA)
// ==========================================
function carregarDadosAnamnese(nomePaciente) {
  if (!nomePaciente) return;
  
  mostrarNotificacao("⏳ Carregando anamnese...", "info");
  
  google.script.run
    .withSuccessHandler(function(jsonString) {
      if (!jsonString || jsonString === '{}' || jsonString === 'null') {
        console.log("Nenhuma anamnese encontrada para:", nomePaciente);
        mostrarNotificacao("ℹ️ Nenhuma anamnese encontrada. Preencha e salve!", "info");
        return;
      }
      
      try {
        const d = JSON.parse(jsonString);
        
        // Preenche automaticamente baseado nas chaves do JSON
        Object.keys(d).forEach(id => {
          const el = document.getElementById(id);
          if (el) {
            if (el.type === 'checkbox') {
              el.checked = d[id] === true;
            } else if (el.type === 'radio') {
              const radio = document.querySelector(`input[id="${id}"][value="${d[id]}"]`);
              if (radio) radio.checked = true;
            } else {
              el.value = d[id] || '';
            }
          }
        });
        
        // Recalcula IMC se tiver peso e altura
        if (document.getElementById('ana_peso')?.value && document.getElementById('ana_altura')?.value) {
          const peso = parseFloat(document.getElementById('ana_peso').value);
          const altura = parseFloat(document.getElementById('ana_altura').value);
          const imcField = document.getElementById('ana_imc');
          if (imcField && peso > 0 && altura > 0) {
            imcField.value = (peso / (altura * altura)).toFixed(1);
          }
        }
        
        mostrarNotificacao("✅ Anamnese carregada!", "sucesso");
        console.log("Anamnese carregada:", Object.keys(d).length, "campos");
        
      } catch (e) {
        console.error("Erro ao processar anamnese:", e);
        mostrarNotificacao("❌ Erro ao carregar anamnese!", "erro");
      }
    })
    .withFailureHandler(function(err) {
      console.error("Erro ao carregar:", err);
      mostrarNotificacao("❌ Erro ao carregar anamnese!", "erro");
    })
    .getDadosAnamnese(nomePaciente);
}
