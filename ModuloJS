function abrirFormulario() {
  document.getElementById("formCadastro").reset();
  document.getElementById("idLinha").value = ""; 
  document.getElementById("btnExcluir").style.display = "none";
  document.getElementById("autocomplete-list").style.display = "none";
  
  const hoje = new Date();
  const dia = String(hoje.getDate()).padStart(2, '0');
  const mes = String(hoje.getMonth() + 1).padStart(2, '0');
  const ano = hoje.getFullYear();
  document.getElementById("dataInput").value = `${dia}/${mes}/${ano}`;
  
  document.getElementById('formCadastro').particular.value = "0,00";
  document.getElementById('formCadastro').vplano.value = "0,00";
  document.getElementById('formCadastro').vlab.value = "0,00";
  new bootstrap.Modal(document.getElementById('modalCadastro')).show();
}

function editarRegistro(idLinha) {
  const r = dadosLocais.find(item => item.id == idLinha);
  if (!r) return;

  const [dia, mes, ano] = r.data.split('/');
  const dataLanc = new Date(ano, mes - 1, dia);
  const hoje = new Date();
  hoje.setHours(0,0,0,0);
  
  const diffDays = (hoje - dataLanc) / (1000 * 60 * 60 * 24);

  if (diffDays > 1 && usuarioLogado.nivel !== "ADMIN") {
    mostrarNotificacao("🚫 Bloqueado: Apenas o Administrador pode editar registros retroativos.", "erro");
    return;
  }

  const form = document.getElementById("formCadastro");
  document.getElementById("idLinha").value = r.id; 
  document.getElementById("btnExcluir").style.display = "block"; 
  document.getElementById("autocomplete-list").style.display = "none";
  
  form.data.value = r.data;
  form.paciente.value = r.paciente; 
  form.doutor.value = r.doutor;
  form.procedimento.value = r.procedimento; 
  form.plano.value = r.plano; 
  form.pagamento.value = r.pagamento; 
  form.obs.value = r.obs;
  
  const converteMoeda = (val) => Number(val).toLocaleString('pt-BR', {minimumFractionDigits: 2, maximumFractionDigits: 2});
  form.particular.value = converteMoeda(r.particular); 
  form.vplano.value = converteMoeda(r.vplano); 
  form.vlab.value = converteMoeda(r.vlab);
  
  new bootstrap.Modal(document.getElementById('modalCadastro')).show();
}

function pedirExclusao() {
  const id = document.getElementById("idLinha").value;
  if (!id || !confirm("Tem certeza que deseja excluir este registro?")) return;
  const btnExcluir = document.getElementById("btnExcluir");
  btnExcluir.disabled = true; btnExcluir.innerHTML = 'EXCLUINDO...';
  
  google.script.run
    .withSuccessHandler((res) => {
      btnExcluir.disabled = false; btnExcluir.innerHTML = 'EXCLUIR REGISTRO';
      bootstrap.Modal.getInstance(document.getElementById('modalCadastro')).hide();
      mostrarNotificacao("✅ " + res, "sucesso"); atualizarTabelaGlobal();
    })
    .withFailureHandler((err) => {
      btnExcluir.disabled = false; btnExcluir.innerHTML = 'EXCLUIR REGISTRO';
      mostrarNotificacao("❌ Erro: " + err, "erro");
    }).excluirLancamento(id);
}

function formatarParaCalculo(valorTela) {
  if (!valorTela) return 0;
  return Number(valorTela.toString().replace(/\./g, '').replace(',', '.')) || 0;
}

