// MÓDULO DA AGENDA (FULLCALENDAR PREMIUM)
// ==========================================
let calendarioObj = null;
let intervaloAtual = '00:30:00';
let filtroDoutorAtual = '';

function filtrarAgendaPorDoutor(nomeDoutor) {
  filtroDoutorAtual = nomeDoutor;
  if (calendarioObj) calendarioObj.refetchEvents();
}

function alterarIntervaloAgenda(novoIntervalo) {
  intervaloAtual = novoIntervalo;
  if (calendarioObj) calendarioObj.setOption('slotDuration', novoIntervalo);
}

function renderizarCalendario(forcarRecarregamento = false) {
  const calendarEl = document.getElementById('calendario-clinica');
  if (!calendarEl) return;
  
  if (calendarioObj && !forcarRecarregamento) {
    setTimeout(() => calendarioObj.render(), 200);
    return;
  }
  
  if (calendarioObj) calendarioObj.destroy();

  try {
      calendarioObj = new FullCalendar.Calendar(calendarEl, {
        locale: 'pt-br',
        initialView: 'timeGridWeek', 
        slotDuration: intervaloAtual, 
        headerToolbar: { left: 'prev,next today', center: 'title', right: 'timeGridWeek,timeGridDay,dayGridMonth' },
        buttonText: { today: 'Hoje', month: 'Mês', week: 'Semana', day: 'Dia' },
        slotMinTime: '08:00:00', slotMaxTime: '20:00:00', allDaySlot: false, nowIndicator: true, height: 750, expandRows: true,

        events: function(fetchInfo, successCallback, failureCallback) {
          google.script.run
            .withSuccessHandler(function(eventosReais) { successCallback(eventosReais); })
            .withFailureHandler(function(err) { console.error(err); failureCallback(err); })
            .getAgendamentosCalendario(filtroDoutorAtual);
        },

        // CLIQUE NUM HORÁRIO VAZIO (NOVO AGENDAMENTO)
        dateClick: function(info) {
          let dataISO = info.dateStr.split('T')[0];
          let hora = info.dateStr.split('T')[1] ? info.dateStr.split('T')[1].substring(0, 5) : "08:00";
          let partes = dataISO.split('-');
          let dataBrasil = `${partes[2]}/${partes[1]}/${partes[0]}`;
          
          abrirModalAgendamento(dataBrasil, hora); // Chama a função normal
        },
        
        // CLIQUE NUM EVENTO (EDITAR AGENDAMENTO)
        eventClick: function(info) {
          const ev = info.event.extendedProps;
          // === A MUDANÇA ESTÁ AQUI ===
          // Em vez de chamar a função que recarrega as listas, nós usamos 
          // a função exclusiva para edição (que não tem delay!)
          abrirEdicaoAgendamento(info.event.id, ev);
        }
      });
      setTimeout(() => calendarioObj.render(), 200);
  } catch (e) {
      console.error("Erro na montagem da agenda: ", e);
  }
}

function abrirModalAgendamento(data, hora) {
  // 1. Limpa o formulário e reseta os campos ocultos
  const form = document.getElementById("formAgendamento");
  if (form) form.reset();
  
  const idAgendamento = document.getElementById("agenda_id");
  if (idAgendamento) idAgendamento.value = "";
  
  const btnExcluir = document.getElementById("btnExcluirAg");
