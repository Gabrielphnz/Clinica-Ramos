// MOTOR DE BUSCA UNIFICADO E BLINDADO (RESOLVE O ERRO DE FILTER)
// ==============================================================
function motorAutocomplete(valor, idLista, idInput) {
  const listEl = document.getElementById(idLista);
  if (!listEl) return;

  if (!valor || valor.trim().length < 2 || !basePacientesCRM) { 
    listEl.style.display = 'none'; 
    return; 
  }
  
  const busca = valor.toString().toLowerCase().trim();

  // 🛡️ BLINDAGEM TOTAL: Só entra no filtro se o paciente E o nome existirem
  const sugestoes = basePacientesCRM.filter(p => {
    try {
      if (p && p.nome) {
        return String(p.nome).toLowerCase().includes(busca);
      }
    } catch (e) { return false; }
    return false;
  }).slice(0, 8);

  if (sugestoes.length === 0) {
    listEl.innerHTML = '<div class="p-3 text-muted small fw-bold text-center">Paciente não encontrado.</div>';
    listEl.style.display = 'block';
    return;
  }

  listEl.innerHTML = sugestoes.map(s => {
    const nomeSeguro = String(s.nome || "Sem Nome").replace(/['"]/g, "");
    const convSeguro = String(s.convenio || "Particular").replace(/['"]/g, "");
    return `
      <div class="p-3 border-bottom" style="cursor:pointer;" 
           onmouseover="this.style.background='#F4F7FE'" onmouseout="this.style.background='#fff'"
           onclick="finalizarSelecaoAutocomplete('${nomeSeguro}', '${convSeguro}', '${idInput}', '${idLista}')">
        <strong style="color:#2B3674;">${s.nome}</strong><br>
        <small style="color:#A3AED0;">💳 ${convSeguro}</small>
      </div>`;
  }).join('');
  listEl.style.display = 'block';
}

function finalizarSelecaoAutocomplete(nome, convenio, idInput, idLista) {
  const input = document.getElementById(idInput);
  if (input) input.value = nome;
  const lista = document.getElementById(idLista);
  if (lista) lista.style.display = 'none';
  if (idInput === 'f_paciente') selecionarPacienteCRM(nome, convenio); 
}

