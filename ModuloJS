// 1. Variável global para guardar a tabela de preços na memória
var tabelaPrecosGlobal = [];

// 2. Carrega a tabela de preços silenciosamente logo que o sistema abre
$(document).ready(function() {
    google.script.run.withSuccessHandler(function(precos) {
        tabelaPrecosGlobal = precos;
    }).apiGetProcedimentosComPreco();
    
    // 3. Conecta os "ouvidos" nos campos de Procedimento e Plano
    $('#sel_proc, #sel_plano').on('change', sugerirPrecoAutomatico);
