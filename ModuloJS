function salvarPacienteCRM() {
  const form = document.getElementById("formPacienteCompleto");
  if (!form.checkValidity()) { form.reportValidity(); return; }

  const btn = event.target;
  btn.disabled = true; btn.innerText = "CADASTRANDO...";

  const dados = {};
  const formData = new FormData(form);
  formData.forEach((value, key) => { dados[key] = value; });

  // === TRAVA DE DUPLICIDADE ===
  // Limpa tudo que não for número para comparar perfeitamente
  const cpfDigitado = dados.CPF ? dados.CPF.replace(/\D/g, '') : '';
  const celDigitado = dados.Celular ? dados.Celular.replace(/\D/g, '') : '';

  if (basePacientesCRM && basePacientesCRM.length > 0) {
    const pacienteDuplicado = basePacientesCRM.find(p => {
      let pCpf = p.cpf ? p.cpf.replace(/\D/g, '') : '';
      let pCel = p.celular ? p.celular.replace(/\D/g, '') : '';
      
      return (cpfDigitado && cpfDigitado.length > 8 && pCpf === cpfDigitado) || 
             (celDigitado && celDigitado.length > 8 && pCel === celDigitado);
    });

    if (pacienteDuplicado) {
      mostrarNotificacao(`❌ Erro: O paciente "${pacienteDuplicado.nome}" já está cadastrado com este CPF ou Celular!`, "erro");
      btn.disabled = false; btn.innerText = "💾 CADASTRAR PACIENTE";
      return; // Trava o envio aqui!
    }
  }
  // ============================

  google.script.run
    .withSuccessHandler(function(res) {
      mostrarNotificacao("✅ Paciente salvo com sucesso!", "sucesso");
      bootstrap.Modal.getInstance(document.getElementById('modalPaciente')).hide();
      btn.disabled = false; btn.innerText = "💾 CADASTRAR PACIENTE";
      
      // Atualiza a memória local para o paciente já aparecer no autocomplete de Lançamentos
      google.script.run.withSuccessHandler(r => { basePacientesCRM = r || []; }).getPacientesCRM();
    })
    .withFailureHandler(function(err) {
      mostrarNotificacao("❌ Erro ao salvar: " + err, "erro");
      btn.disabled = false; btn.innerText = "💾 CADASTRAR PACIENTE";
    })
    .cadastrarPacienteNoCRM(dados);
}

