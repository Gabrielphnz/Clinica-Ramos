// 2. Ação de Salvar Novo ou Excluir (Comunica com o Servidor)
window.acaoGestor = function(aba, acao, id) {
    let dados = {};
    
    // Coleta os dados dependendo de qual sanfona o usuário está usando
    if (aba === 'PROFISSIONAIS') {
        dados = { 
            nome: document.getElementById('gestorProfNome').value, 
            registro_cro: document.getElementById('gestorProfCro').value, 
            endereco_clinica: document.getElementById('gestorProfEnd').value 
        };
    } else {
        dados = { 
            finalidade: document.getElementById('gestorProtFin').value, 
            medicamento: document.getElementById('gestorProtMed').value, 
            quantidade: document.getElementById('gestorProtQtd').value, 
            uso: document.getElementById('gestorProtUso').value, 
            posologia: document.getElementById('gestorProtPos').value 
        };
    }

    const btnClicado = event.target.closest('button');
    const textoOriginal = btnClicado.innerHTML;
    
    if (acao === 'excluir') {
        if (!confirm("Deseja mesmo excluir este item permanentemente?")) return; 
        
        btnClicado.innerHTML = `<span class="spinner-border spinner-border-sm text-danger"></span>`;
        
        google.script.run.withSuccessHandler(() => {
            mostrarNotificacao("Excluído com sucesso!", "sucesso");
            window.carregarConfiguracoesReceita(); // Atualiza a tela automaticamente
        }).excluirItemConfig(aba, id);
        
    } else {
        // Trava para não salvar vazio
        if (aba === 'PROFISSIONAIS' && !dados.nome) return mostrarNotificacao("Preencha o nome do Doutor!", "erro");
        if (aba === 'PROTOCOLOS' && !dados.finalidade) return mostrarNotificacao("Preencha a finalidade do Protocolo!", "erro");

        btnClicado.innerHTML = "⏳...";
        btnClicado.disabled = true;

        google.script.run.withSuccessHandler(() => {
            mostrarNotificacao("Salvo com sucesso!", "sucesso");
            btnClicado.innerHTML = textoOriginal;
            btnClicado.disabled = false;
            
            // Limpa as caixinhas de texto após salvar
            if (aba === 'PROFISSIONAIS') {
                document.getElementById('gestorProfNome').value = "";
                document.getElementById('gestorProfCro').value = "";
                document.getElementById('gestorProfEnd').value = "";
            } else {
                document.getElementById('gestorProtFin').value = "";
                document.getElementById('gestorProtMed').value = "";
                document.getElementById('gestorProtQtd').value = "";
                document.getElementById('gestorProtUso').value = "";
                document.getElementById('gestorProtPos').value = "";
            }
            
            // Recarrega os dados e pinta as listas na hora!
            window.carregarConfiguracoesReceita(); 
            
        }).salvarItemConfig(aba, dados);
    }
};

