function recalcularSubtotalManual(el) {
    const tr = el.closest('tr');
    const qtd = Number(tr.querySelector('.qtd-final').value) || 0;
    let precoStr = tr.querySelector('.i-val-manual').value.replace('R$ ', '').replace(/\./g, '').replace(',', '.');
    const preco = Number(precoStr) || 0;
    tr.querySelector('.subtotal-item').innerText = "R$ " + (qtd * preco).toFixed(2).replace('.', ',');
    recalcularTotalGeral();
}

function recalcularSubtotalPedido(el) {
    const tr = el.closest('tr');
    const qtd = Number(tr.querySelector('.qtd-final').value) || 0;
    const select = tr.querySelector('.sel-fornecedor');
    if (select) {
        const preco = Number(select.value) || 0;
        tr.querySelector('.unit-val').innerText = "R$ " + preco.toFixed(2).replace('.', ',');
        tr.querySelector('.subtotal-item').innerText = "R$ " + (qtd * preco).toFixed(2).replace('.', ',');
    }
    recalcularTotalGeral();
}

function recalcularTotalGeral() {
    let total = 0;
    document.querySelectorAll('.subtotal-item').forEach(td => {
        let valor = td.innerText.replace('R$ ', '').replace(/\./g, '').replace(',', '.');
        total += Number(valor) || 0;
    });
    document.getElementById('totalGeralPedido').innerText = "R$ " + total.toLocaleString('pt-BR', {minimumFractionDigits: 2});
}

