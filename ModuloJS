// RESTAURAÇÃO DA FUNÇÃO DO PREÇO (Sem tentar copiar pra outro canto)
function sugerirPrecoAutomatico() {
    const form = document.getElementById("formCadastro");
    if (!form) return;

    const procSelecionado = form.procedimento.value;
    const planoSelecionado = form.plano.value;

    if (!procSelecionado) return;
    const item = tabelaPrecosGlobal.find(p => p.proc.toUpperCase() === procSelecionado.toUpperCase());
    if (!item || !item.preco) return; 

    const precoFormatado = Number(item.preco).toLocaleString('pt-BR', {minimumFractionDigits: 2, maximumFractionDigits: 2});

    if (!planoSelecionado || planoSelecionado.toUpperCase().includes("PARTICULAR")) {
        form.particular.value = precoFormatado;
        form.vplano.value = "0,00"; 
        document.getElementById('taxaCartaoInp').value = "0,00";
    } else {
        form.vplano.value = precoFormatado;
        form.particular.value = "0,00";
        document.getElementById('taxaCartaoInp').value = "0,00";
    }
}

