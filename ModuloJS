// PDF ALMOXARIFADO
function exportarPDFEstoque(tipo) {
  executarComPDF(function(jsPDF) {
      const doc = new jsPDF();
      const titulo = tipo === 'CONTAGEM' ? "Relatório de Inventário Físico" : "Lista de Necessidade de Compra";
      doc.setFontSize(18); doc.text(titulo, 14, 20);
      doc.setFontSize(10); doc.text("Clínica Ramos - Data: " + new Date().toLocaleDateString('pt-BR'), 14, 28);

      let dadosPdf = estoqueCompletoCache;
      if (tipo === 'COMPRAS') { dadosPdf = estoqueCompletoCache.filter(p => p.atual <= p.minimo); }

      const colunas = ["ID", "CATEGORIA", "PRODUTO", "ESTOQUE", tipo === 'CONTAGEM' ? "CONTAGEM REAL" : "PEDIR (QTD)"];
      const linhas = dadosPdf.map(p => ["#" + p.id, p.categoria, p.nome, p.atual, "_______" ]);

      doc.autoTable({
        startY: 35, head: [colunas], body: linhas, theme: 'grid',
        headStyles: { fillColor: tipo === 'CONTAGEM' ? [67, 24, 255] : [5, 205, 153] }
      });

      doc.save(`${tipo.toLowerCase()}_ramos.pdf`);
      mostrarNotificacao("PDF baixado!", "sucesso");
  });
}
