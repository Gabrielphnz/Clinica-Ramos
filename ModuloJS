function carregarPainelRetornos() {
  const corpo = document.getElementById("tabelaRetornos");
  corpo.innerHTML = '<tr><td colspan="6" class="text-center py-4"><div class="spinner-border text-primary spinner-border-sm"></div> Processando pacientes...</td></tr>';

  google.script.run.withSuccessHandler(function(regrasCadastradas) {
      google.script.run.withSuccessHandler(function(retornos) {
          if (retornos.length === 0) {
            corpo.innerHTML = '<tr><td colspan="6" class="text-center py-4 text-success fw-bold">Nenhum retorno pendente!</td></tr>';
            return;
          }
          corpo.innerHTML = retornos.map(r => {
            let badgeStatus = r.status === "AGENDADO" ? '<span class="badge bg-success bg-opacity-10 text-success border border-success">Agendado</span>' : (r.status === "VENCIDO" ? `<span class="badge bg-danger">Atrasado ${r.atraso}</span>` : '<span class="badge bg-warning text-dark">Em breve</span>');
            
            // --- OS 3 BOTÕES DE AÇÃO ---
            let btnWpp = '';
            if (r.celular && r.status !== 'AGENDADO') {
                let num = r.celular.replace(/\D/g, '');
                if (num.length >= 10) {
                    num = num.length === 10 ? "55" + num.substring(0,2) + "9" + num.substring(2) : "55" + num;
                    let txt = encodeURIComponent(`Olá, ${r.paciente}! Aqui é da Clínica Ramos. Já está na hora do retorno para ${r.procedimento}. Vamos agendar?`);
                    btnWpp = `<a href="https://api.whatsapp.com/send?phone=${num}&text=${txt}" target="_blank" class="btn btn-sm btn-success rounded-circle p-2 d-inline-flex" title="WhatsApp"><span class="material-icons" style="font-size: 16px;">chat</span></a>`;
                }
            }
            
            // BOTÃO PRONTUÁRIO
            let btnProntuario = `<button class="btn btn-sm btn-outline-primary rounded-circle p-2 d-inline-flex ms-1" onclick="abrirProntuario('${r.paciente}')" title="Prontuário"><span class="material-icons" style="font-size: 16px;">assignment_ind</span></button>`;
            
            // BOTÃO LIXEIRA (X)
            let btnApagar = `<button class="btn btn-sm btn-outline-danger rounded-circle p-2 d-inline-flex ms-1" onclick="ocultarPacienteDaLista('${r.paciente}', '${r.procedimento}', '${r.ultimaData}')" title="Ignorar esta data"><span class="material-icons" style="font-size: 16px;">delete_outline</span></button>`;
            // ---------------------------

            return `<tr>
                <td class="ps-4 fw-bold text-dark">${r.paciente}</td>
