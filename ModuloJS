function fecharGerenciamentoLab() {
  const m = bootstrap.Modal.getInstance(document.getElementById('modalGerenciamentoLab'));
  if (m) m.hide();
}

function carregarTabelaLab() {
  const tbody = document.getElementById('tabelaGerenciamentoLab');
  if (!tbody) return;
  
  tbody.innerHTML = '<tr><td colspan="6" class="text-center py-5 text-muted"><div class="spinner-border spinner-border-sm text-info"></div> Processando dados do laboratório...</td></tr>';
  
  google.script.run.withSuccessHandler(function(lista) {
    // SALVA-VIDAS CONTRA O ERRO NULL:
    if (!lista) lista = []; 

    if (lista.length === 0) {
      tbody.innerHTML = '<tr><td colspan="6" class="text-center py-5 text-success fw-bold">Nenhum trabalho cadastrado no laboratório!</td></tr>';
      return;
    }
    
    let htmlLinhas = "";
    lista.forEach(r => {
      let badgeStatus = r.status === "FINALIZADO" 
         ? '<span class="badge bg-success bg-opacity-10 text-success border border-success">Entregue</span>' 
         : '<span class="badge bg-warning text-dark">Em andamento</span>';
         
      // Verifica Atraso se não estiver entregue
      if (r.status !== "FINALIZADO") {
          const hoje = new Date(); hoje.setHours(0,0,0,0);
          const partes = (r.previsao || "").toString().split('/');
          if (partes.length === 3) {
              const prev = new Date(partes[2], partes[1]-1, partes[0]);
              if (prev < hoje) badgeStatus = '<span class="badge bg-danger">Atrasado</span>';
          }
      }

      // Os 4 Botões (Concluir, Agendar, Editar, Excluir)
      let btnConcluir = r.status !== "FINALIZADO" ? `<button class="btn btn-sm btn-success rounded-circle p-2 d-inline-flex shadow-sm ms-1" onclick="finalizarAlertaLab('${r.id}')" title="Marcar como Recebido"><span class="material-icons" style="font-size: 16px;">check</span></button>` : '';
      let btnAgendar = `<button class="btn btn-sm btn-primary rounded-circle p-2 d-inline-flex shadow-sm ms-1" onclick="abrirAgendamentoComNome('${r.paciente}'); fecharGerenciamentoLab();" title="Agendar Paciente"><span class="material-icons" style="font-size: 16px;">calendar_month</span></button>`;
      let btnEditar = `<button class="btn btn-sm btn-warning rounded-circle p-2 d-inline-flex shadow-sm ms-1" onclick="editarPedidoLab('${r.id}', '${r.paciente}', '${r.proc}', '${r.lab}', '${r.prazo}')" title="Editar Pedido"><span class="material-icons text-white" style="font-size: 16px;">edit</span></button>`;
      let btnApagar = `<button class="btn btn-sm btn-outline-danger rounded-circle p-2 d-inline-flex shadow-sm ms-1 border-0" onclick="excluirPedidoLab('${r.id}')" title="Excluir"><span class="material-icons" style="font-size: 16px;">delete_outline</span></button>`;

      htmlLinhas += `<tr>
        <td class="ps-4 fw-bold text-dark">${r.paciente}</td>
        <td><span class="text-secondary fw-bold" style="font-size: 13px;">${r.proc}</span></td>
        <td><span class="badge bg-light text-info border">${r.lab}</span></td>
        <td class="fw-bold ${badgeStatus.includes('Atrasado') ? 'text-danger' : 'text-dark'}">${r.previsao}</td>
        <td>${badgeStatus}</td>
        <td class="text-center pe-4">
          <div class="d-flex justify-content-center align-items-center">
             ${btnConcluir}${btnAgendar}${btnEditar}${btnApagar}
          </div>
        </td>
      </tr>`;
    });
    tbody.innerHTML = htmlLinhas;
  }).apiGetTodosLaboratorios();
}


function excluirPedidoLab(id) {
    if(!confirm("Excluir este pedido do laboratório permanentemente?")) return;
    document.getElementById('tabelaGerenciamentoLab').innerHTML = '<tr><td colspan="6" class="text-center py-4 text-danger fw-bold"><div class="spinner-border text-danger spinner-border-sm"></div> Excluindo registro...</td></tr>';
    google.script.run.withSuccessHandler(function(res) {
        mostrarNotificacao(res, "sucesso");
        carregarTabelaLab();
        carregarNotificacoes();
    }).apiExcluirLaboratorio(id);
}

function editarPedidoLab(id, paciente, proc, lab, prazo) {
    invocarTelaLaboratorio(paciente, proc); // Abre a tela de cadastro por cima
    
    // Injeta os dados antigos na tela para você alterar
    setTimeout(() => {
        document.getElementById('lab_nome_empresa').value = lab;
        document.getElementById('lab_prazo_dias').value = prazo;
        
        // Cria um campo invisível para o sistema saber que é uma edição
        let hiddenId = document.getElementById('lab_id_edicao');
        if (!hiddenId) {
            hiddenId = document.createElement('input');
            hiddenId.type = 'hidden';
            hiddenId.id = 'lab_id_edicao';
            document.getElementById('modalCadastroLab').appendChild(hiddenId);
        }
        hiddenId.value = id;
    }, 300);
