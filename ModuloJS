            $("#resumoPartHtml").text(formataReal(somaPart)); $("#resumoPlanoHtml").text(formataReal(somaPlano));
          } else { $("#cardsFiltrados").hide(); }
        }
      });
  }

  configurarAcessoBotoes();
  $("#loader").hide(); $("#conteudo").show();
}

function getPacientesCRM() {
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const aba = ss.getSheetByName("PACIENTES"); 
  if (!aba) return [];

  const dados = aba.getDataRange().getValues();
  if (dados.length < 2) return [];

  // Remove acentos e converte para minúsculo para busca infalível
  const cabecalho = dados[0].map(c => c.toString().normalize("NFD").replace(/[\u0300-\u036f]/g, "").toLowerCase().trim());

  // Caçador inteligente de colunas
  const achar = (palavras) => {
     for(let i=0; i<cabecalho.length; i++) {
        for(let p of palavras) {
           if(cabecalho[i] === p || cabecalho[i].includes(p)) return i;
        }
     }
     return -1;
  };

  const iNome = achar(["nome"]);
  const iCpf = achar(["cpf"]);
  const iRg = achar(["rg", "identidade"]);
  const iNasc = achar(["nascimento", "nasc"]);
  const iCel = achar(["celular", "whats"]);
  const iTel = achar(["telefone", "fixo", "recado"]);
  const iEmail = achar(["email", "mail"]);
  const iConv = achar(["convenio", "plano"]);
  const iEnd = achar(["endereco", "end"]);
  const iResp = achar(["responsavel", "menor", "resp"]);
  const iProf = achar(["profissao", "prof"]);
  const iSexo = achar(["sexo", "genero"]);

  const lista = [];
  for (let i = 1; i < dados.length; i++) {
    const r = dados[i];
    if (iNome === -1 || !r[iNome] || r[iNome].toString().trim() === "") continue;

    let dtNasc = iNasc >= 0 ? r[iNasc] : "";
    if (dtNasc instanceof Date) {
      dtNasc = Utilities.formatDate(dtNasc, ss.getSpreadsheetTimeZone(), "dd/MM/yyyy");
    }

    lista.push({
      nome: String(r[iNome]).trim(),
      cpf: iCpf >= 0 ? String(r[iCpf] || "") : "",
      rg: iRg >= 0 ? String(r[iRg] || "") : "",
      nascimento: dtNasc ? String(dtNasc) : "",
      celular: iCel >= 0 ? String(r[iCel] || "") : "",
      telefone: iTel >= 0 ? String(r[iTel] || "") : "",
      email: iEmail >= 0 ? String(r[iEmail] || "") : "",
      convenio: iConv >= 0 ? String(r[iConv] || "") : "Particular",
      endereco: iEnd >= 0 ? String(r[iEnd] || "") : "",
      responsavel: iResp >= 0 ? String(r[iResp] || "") : "",
      profissao: iProf >= 0 ? String(r[iProf] || "") : "",
      sexo: iSexo >= 0 ? String(r[iSexo] || "") : ""
    });
  }
  return lista;
}


