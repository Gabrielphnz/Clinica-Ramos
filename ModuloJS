  const corpo = document.getElementById("tabelaRetornos");
  corpo.innerHTML = '<tr><td colspan="6" class="text-center py-4"><div class="spinner-border text-primary"></div> Mapeando base de pacientes...</td></tr>';

  google.script.run
    .withSuccessHandler(function(retornos) {
      if (retornos.length === 0) {
        corpo.innerHTML = '<tr><td colspan="6" class="text-center py-4 text-success fw-bold">Nenhum retorno pendente! Todos estão em dia ou agendados.</td></tr>';
        return;
      }

      corpo.innerHTML = retornos.map(r => {
        let badgeStatus = '';
        if (r.status === "AGENDADO") badgeStatus = '<span class="badge bg-success bg-opacity-10 text-success border border-success">Já Agendado</span>';
        else if (r.status === "VENCIDO") badgeStatus = `<span class="badge bg-danger">Atrasado ${r.atraso}</span>`;
        else badgeStatus = '<span class="badge bg-warning text-dark">Vence em breve</span>';

        // Botão de WhatsApp inteligente
        let btnWpp = '';
        if (r.celular) {
            let numero = r.celular.replace(/\D/g, '');
            if (numero.length >= 10) {
                if (numero.length === 10) numero = "55" + numero.substring(0,2) + "9" + numero.substring(2);
                else if (numero.length === 11) numero = "55" + numero;
                
                let texto = encodeURIComponent(`Olá, ${r.paciente}! Aqui é da Clínica Ramos. Vimos que já está na hora do seu retorno para a ${r.procedimento}. Vamos agendar?`);
                btnWpp = `<a href="https://api.whatsapp.com/send?phone=${numero}&text=${texto}" target="_blank" class="btn btn-sm btn-success rounded-pill fw-bold"><i class="fa-brands fa-whatsapp"></i> Chamar</a>`;
            }
        }

        return `
          <tr>
            <td class="ps-4 fw-bold text-dark">${r.paciente}</td>
            <td><span class="badge bg-light text-primary border">${r.procedimento.toUpperCase()}</span></td>
            <td class="text-muted">${r.ultimaData}</td>
            <td class="fw-bold ${r.status === 'VENCIDO' ? 'text-danger' : 'text-dark'}">${r.vencimento}</td>
            <td>${badgeStatus}</td>
            <td class="text-center pe-4">
              ${r.status !== 'AGENDADO' ? btnWpp : '<span class="text-muted small">Aguardando Consulta</span>'}
            </td>
          </tr>
        `;
      }).join('');
    })
    .calcularRetornosPendentes(REGRAS_CLINICA);
}


// ABRIR MODAL INTELIGENTE (Evita sobreposição de telas pretas)
function abrirModalRecall() {
  const modalEl = document.getElementById('modalRecall');
  
  // Pega o modal se ele já existir na memória, se não, cria UM SÓ
  let modalInstancia = bootstrap.Modal.getInstance(modalEl) || new bootstrap.Modal(modalEl);
  modalInstancia.show();
  
  carregarPainelRetornos();
}

// FECHAR MODAL À FORÇA (Limpa qualquer tela travada)
function fecharModalRecall() {
  const modalEl = document.getElementById('modalRecall');
  const modalInstancia = bootstrap.Modal.getInstance(modalEl);
  if (modalInstancia) modalInstancia.hide();
  
  // O "Trator": Arranca qualquer fundo escuro que tenha ficado travado na tela
  document.querySelectorAll('.modal-backdrop').forEach(el => el.remove());
  document.body.classList.remove('modal-open');
  document.body.style.overflow = 'auto';
  document.body.style.paddingRight = '';
}

