function gerarPDFFinal(tipo) {
  const btn = event.target;
  const pac = pacienteAtualProntuario;
  if (!pac) return;

  btn.disabled = true;
  btn.innerHTML = `<span class="spinner-border spinner-border-sm"></span> CRIANDO PDF...`;

  let dadosDoc = {};
  let htmlVias = "";
  const dataHoje = new Date().toLocaleDateString('pt-BR');
  const docId = pac.cpf ? "CPF: " + pac.cpf : (pac.rg ? "RG: " + pac.rg : "Doc: --");

  let nomeDoutor = "Dra. Giovanna Ramos";
  let croDoutor = "CRO/SC 19773";
  const selDoc = document.getElementById("recDoutorSelecionado");
  if (selDoc && window.cacheConfig && window.cacheConfig.profissionais) {
      const profInfo = window.cacheConfig.profissionais[selDoc.value];
