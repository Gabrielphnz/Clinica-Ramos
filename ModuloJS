  // Adicionei o onkeydown nos campos de Valor e Observação para escutar o Enter!
  div.innerHTML = `
    <div class="col-md-3"><input type="text" class="form-control border-0 fw-bold text-primary input-produto" list="listaProdutosCatalogo" onchange="tratarIndexador(this)" placeholder="ID ou Nome..." required></div>
