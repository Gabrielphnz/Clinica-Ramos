            textoResumo += med + ", ";
        }
    }
    if (!temMedicamento) { btn.disabled = false; btn.innerText = "GERAR PDF DA RECEITA"; return mostrarNotificacao("Adicione medicamentos!", "erro"); }
    htmlVias = layoutBase("RECEITUÁRIO", "1ª VIA - FARMÁCIA", textoHtmlReceita) + layoutBase("RECEITUÁRIO", "2ª VIA - PACIENTE", textoHtmlReceita);
    dadosDoc.resumo = textoResumo.substring(0, 50);
  } 
  
  else if (tipo === 'ATESTADO' || tipo === 'DECLARACAO') {
    const horaIni = document.getElementById('docAtIni').value; const horaFim = document.getElementById('docAtFim').value;
    if (!horaIni || !horaFim) { btn.disabled = false; btn.innerText = `GERAR ${tipo}`; return mostrarNotificacao("Preencha os horários!", "erro"); }
