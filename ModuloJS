// PDF DO PEDIDO (INTELIGENTE PARA LER OS ITENS NOVOS)
// -------------------------------------------------------------
function gerarPDFOrdemCompra(idPedido) {
  executarComPDF(function(jsPDF) {
      mostrarNotificacao("Gerando Pedido e salvando no histórico...", "info");
      const doc = new jsPDF();
      
      doc.setFontSize(20);
      doc.setTextColor(43, 54, 116);
      doc.text("PEDIDO DE COMPRA - CLÍNICA RAMOS", 14, 20);
      
      doc.setFontSize(10);
      doc.setTextColor(100);
      doc.text("DOCUMENTO Nº: " + idPedido, 14, 28);
      doc.text("DATA DE EMISSÃO: " + new Date().toLocaleDateString('pt-BR'), 14, 33);

      let dadosPdf = [];
      let totalPedido = 0;
      let itensParaSalvar = [];

      // Lê a tabela de decisão na tela
      document.querySelectorAll('#tabelaDecisaoCompra tbody tr').forEach(tr => {
         const inputNome = tr.querySelector('.i-prod-manual');
         const produto = inputNome ? inputNome.value : tr.querySelector('td:nth-child(1)').innerText;
         const qtd = tr.querySelector('.qtd-final').value;
         
         const select = tr.querySelector('.sel-fornecedor');
         let fornecedor, preco;
         
         if (select) {
             fornecedor = select.options[select.selectedIndex].getAttribute('data-forn');
             preco = Number(select.value);
         } else {
             fornecedor = tr.querySelector('.i-forn-manual').value;
             let pStr = tr.querySelector('.i-val-manual').value.replace(/\./g, '').replace(',', '.');
             preco = Number(pStr) || 0;
         }

         const subtotal = preco * qtd;
         totalPedido += subtotal;
         
         if(produto && fornecedor) {
            let strSubtotalFormatado = subtotal.toFixed(2).replace('.', ',');
            dadosPdf.push([produto, qtd, fornecedor, "R$ " + preco.toFixed(2).replace('.', ','), "R$ " + strSubtotalFormatado]);
            
            // Cria a memória do item para a importação futura
            itensParaSalvar.push({
                produto: produto,
                qtd: qtd,
                subtotal: strSubtotalFormatado
            });
         }
      });

      // Salva o pedido no Histórico do Navegador (Para o botão de Importar)
      let historico = JSON.parse(localStorage.getItem('ramos_pedidos_salvos') || '{}');
      historico[idPedido] = { data: new Date().toISOString(), itens: itensParaSalvar };
      localStorage.setItem('ramos_pedidos_salvos', JSON.stringify(historico));

      doc.autoTable({
        startY: 40,
        head: [["PRODUTO", "QTD", "FORNECEDOR", "VALOR UNIT.", "SUBTOTAL"]],
        body: dadosPdf,
        theme: 'grid',
        headStyles: { fillColor: [43, 54, 116], fontStyle: 'bold' },
        columnStyles: { 1: { halign: 'center' }, 3: { halign: 'right' }, 4: { halign: 'right' } }
      });

      let finalY = doc.lastAutoTable.finalY + 15;
      doc.setFontSize(14);
      doc.setTextColor(5, 205, 153);
      doc.text("VALOR TOTAL DO PEDIDO: R$ " + totalPedido.toLocaleString('pt-BR', {minimumFractionDigits: 2}), 14, finalY);

      doc.save(`${idPedido}.pdf`);
      mostrarNotificacao("Pedido exportado e salvo no histórico local!", "sucesso");
      bootstrap.Modal.getInstance(document.getElementById('modalDecisao')).hide();
  });
}

