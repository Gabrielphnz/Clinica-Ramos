function carregarHistoricoFinanceiroFicha(nomePaciente) {
  if (!dadosLocais || dadosLocais.length === 0) {
    injetarLinhasHistorico('<tr><td colspan="4" class="text-center text-muted py-4">Nenhum dado financeiro carregado.</td></tr>');
    return;
  }
  const busca = nomePaciente.toString().trim().toLowerCase();
  const historico = dadosLocais.filter(lanc => (lanc && lanc.paciente) ? lanc.paciente.toString().trim().toLowerCase() === busca : false);

  if (historico.length === 0) {
    atualizarEstatisticasLateral("--/--/----", 0, 0);
    injetarLinhasHistorico('<tr><td colspan="4" class="text-center text-muted py-4">Nenhum procedimento registrado.</td></tr>');
    return;
  }

  historico.sort((a, b) => {
    const [dA, mA, yA] = a.data.split('/');
    const [dB, mB, yB] = b.data.split('/');
    return new Date(yB, mB - 1, dB) - new Date(yA, mA - 1, dA);
  });

  const extrairValor = (str) => {
    if (!str) return 0;
    if (typeof str === 'number') return str;
    let limpo = str.toString().replace(/[^\d,-]/g, '').replace(',', '.');
    return Number(limpo) || 0;
  };

  let totalGasto = 0;
  const linhasHTML = historico.map(lanc => {
    const valorRow = extrairValor(lanc.particular) + extrairValor(lanc.vplano);
    totalGasto += valorRow;
    return `<tr class="border-bottom">
        <td class="fw-bold text-dark align-middle ps-2 py-3">${lanc.data || '-'}</td>
        <td class="align-middle"><span class="badge bg-light text-primary border px-2 py-1">${lanc.procedimento || '-'}</span></td>
        <td class="text-muted small align-middle">${lanc.doutor || '-'}</td>
        <td class="fw-bold text-success text-end align-middle pe-2">${valorRow.toLocaleString('pt-BR', {style: 'currency', currency: 'BRL'})}</td>
      </tr>`;
  }).join('');

  atualizarEstatisticasLateral(historico[0].data, historico.length, totalGasto);
  injetarLinhasHistorico(linhasHTML);
}

// --- PREENCHE A AGENDA DA FICHA ---
function carregarProximasConsultas(nome) {
  const corpo = document.getElementById("ficha_proximas_consultas");
  if (!corpo) return;
  corpo.innerHTML = '<tr><td colspan="5" class="text-center py-4 text-muted"><div class="spinner-border spinner-border-sm text-warning"></div> Buscando na agenda...</td></tr>';
  
  google.script.run.withSuccessHandler(function(agendamentos) {
     // Filtra só as consultas futuras desse paciente
     const futuras = agendamentos.filter(a => a.paciente.toLowerCase() === nome.toLowerCase() && a.status !== 'FINALIZADO' && a.status !== 'FALTOU');
     
     if (futuras.length === 0) {
        corpo.innerHTML = '<tr><td colspan="5" class="text-center py-4 text-muted">Nenhuma consulta futura agendada.</td></tr>';
        return;
     }
     
     corpo.innerHTML = futuras.map(a => {
         // Converte de AAAA-MM-DD para DD/MM/AAAA visualmente
         let dataBR = a.data;
         if (dataBR && dataBR.includes('-')) {
             const partes = dataBR.split('-');
             dataBR = `${partes[2]}/${partes[1]}/${partes[0]}`;
         }
         
         return `<tr><td class="ps-4 fw-bold">${dataBR}</td><td>${a.hora}</td><td>${a.proc}</td><td>${a.doutor}</td>
         <td class="text-center pe-4"><span class="badge bg-warning text-dark">${a.status}</span></td></tr>`;
       }).join('');

  }).getAgendamentosCalendario('');
}

function editarDadosPaciente() {
  if (!pacienteAtualProntuario) return;
  const p = pacienteAtualProntuario;

  const modalElem = document.getElementById('modalPaciente');
  bootstrap.Modal.getOrCreateInstance(modalElem).show();

  setTimeout(() => {
    const form = document.getElementById('formPacienteCompleto');
    
    // Função auxiliar que busca pelo atributo 'name' do input
    const set = (nameAttr, valor) => {
      const el = form.querySelector('[name="' + nameAttr + '"]');
      if (el) el.value = valor || "";
    };

    // MAPEAMENTO: [Nome no HTML] -> [Propriedade no Objeto do Backend]
    set('Nome', p.nome);
    set('CPF', p.cpf);
    set('RG', p.rg);
    set('Celular', p.celular);
    set('Telefone', p.telefone);
    set('Email', p.email);
    set('sexo', p.sexo);
    set('profissao', p.profissao);
    set('convenio', p.convenio);
    set('Endereco', p.endereco);
    set('Responsavel', p.responsavel);
    
    // Campo invisível essencial para não duplicar o cadastro
    const inputOriginal = document.getElementById('paciente_original_nome');
    if(inputOriginal) inputOriginal.value = p.nome;

    // Tratamento da Data de Nascimento para o input type="date"
    const inputNasc = form.querySelector('[name="Nascimento"]');
    if (inputNasc && p.nascimento && p.nascimento.includes('/')) {
        const pts = p.nascimento.split('/');
        inputNasc.value = pts[2] + '-' + pts[1] + '-' + pts[0]; // Formato yyyy-mm-dd
    }
    
    document.getElementById('tituloModalPaciente').innerText = "Editar Cadastro";
    document.getElementById('btnSalvarPaciente').innerText = "💾 ATUALIZAR CADASTRO";
    document.getElementById('btnSalvarPaciente').className = "btn btn-warning fw-bold px-5 rounded-pill shadow-sm";
  }, 400);
}


