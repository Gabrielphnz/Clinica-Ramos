      const conteudoHtml = `<div style="text-align: justify; line-height: 1.8;">${textoEditado.replace(/\n/g, '<br>')}</div>`;
      
      // O SEGREDO DO LAYOUT: page-break-inside: avoid; impede de cortar a assinatura no meio
      const assinaturaContrato = `
        <div style="page-break-inside: avoid; display: flex; justify-content: space-between; margin-top: 80px; text-align: center; font-size: 14px;">
          <div style="width: 45%;">
            <div style="border-top: 1px solid #2B3674; margin-bottom: 5px;"></div>
            <strong>${nomeDoutor}</strong><br><small>CONTRATADO(A)</small>
          </div>
          <div style="width: 45%;">
            <div style="border-top: 1px solid #2B3674; margin-bottom: 5px;"></div>
            <strong>${pac.nome}</strong><br><small>CONTRATANTE</small>
          </div>
        </div>
      `;
      
      htmlVias = layoutBase("CONTRATO DE PRESTAÇÃO DE SERVIÇOS", "", conteudoHtml, assinaturaContrato);
      dadosDoc.resumo = "Contrato - Chave: " + hashAutenticidade;
  }

  // ENVIO PARA O SERVIDOR E ABERTURA DO PAINEL DE AÇÕES
google.script.run
    .withSuccessHandler(function(res) {
      btn.disabled = false; btn.innerText = "GERAR PDF DA " + tipo;
