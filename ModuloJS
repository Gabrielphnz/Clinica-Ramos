// UPLOAD DE DOCUMENTOS EXTERNOS (RAIO-X, FOTOS, ETC)
// ==========================================
function processarUploadDocumento(event) {
  const file = event.target.files[0];
  if (!file) return;

  if (!pacienteAtualProntuario) return mostrarNotificacao("Abra a ficha de um paciente primeiro!", "erro");

  // Trava de segurança: máximo de 5MB para o Apps Script não engasgar
  if (file.size > 5 * 1024 * 1024) {
    return mostrarNotificacao("O arquivo é muito grande! Máximo permitido: 5MB", "erro");
  }

  mostrarNotificacao("⏳ Enviando arquivo para o Drive...", "info");

  const reader = new FileReader();
  reader.onload = function(e) {
    const base64Data = e.target.result.split(',')[1]; // Pega a base64 crua
    
    const payload = {
      paciente: pacienteAtualProntuario.nome,
      nomeArquivo: file.name,
      mimeType: file.type,
      base64: base64Data
    };

    google.script.run
      .withSuccessHandler(function(res) {
        mostrarNotificacao("✅ Arquivo anexado com sucesso!", "sucesso");
        carregarHistoricoDocumentos(pacienteAtualProntuario.nome); // Atualiza a tabela na hora
      })
      .withFailureHandler(function(err) {
        mostrarNotificacao("❌ Erro no upload: " + err, "erro");
      })
      .apiUploadArquivoPaciente(payload);
  };
  reader.readAsDataURL(file);
}


