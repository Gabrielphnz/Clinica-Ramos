    const injetar = (palavras, valor) => {
        for (let inp of inputs) {
            if (inp.name && palavras.some(pal => inp.name.normalize("NFD").replace(/[\u0300-\u036f]/g, "").toLowerCase().includes(pal))) {
                inp.value = valor || ""; return;
            }
        }
    };

    injetar(["nome"], p.nome);
    injetar(["cpf"], p.cpf);
    injetar(["rg", "identidade"], p.rg);
    injetar(["celular", "whats"], p.celular);
    injetar(["telefone", "fixo", "recado"], p.telefone);
    injetar(["email"], p.email);
    injetar(["sexo", "genero"], p.sexo);
    injetar(["profissao", "prof"], p.profissao);
    injetar(["convenio", "plano"], p.convenio);
