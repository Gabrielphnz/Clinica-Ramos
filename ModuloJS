         <strong>Chave de Autenticidade: ${hashAutenticidade}</strong>
      </div>
    </div>`;
  };

  // --- ROTAS DOS DOCUMENTOS ---
  if (tipo === 'RECEITA') {
    let textoHtmlReceita = ""; let textoResumo = ""; let temMedicamento = false;
    for (let i = 1; i <= window.contadorMedicamentos; i++) {
        const elMed = document.getElementById(`recMed_${i}`);
        if (elMed && elMed.value.trim() !== "") {
            temMedicamento = true;
            const med = elMed.value; const qtd = document.getElementById(`recQtd_${i}`).value || ''; const uso = document.getElementById(`recUso_${i}`).value || ''; const pos = document.getElementById(`recPoso_${i}`).value || '';
