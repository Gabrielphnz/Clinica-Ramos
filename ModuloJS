function verificarTipoPagamento(valor) {
    const painel = document.getElementById('detalhesCartao');
    const valorLimpo = valor.toString().toUpperCase();
    
    // Mostra o painel se a palavra "CARTAO" ou "CARTÃO" for detectada
    if (valorLimpo.includes("CARTÃO") || valorLimpo.includes("CARTAO")) {
        painel.style.display = "block";
        calcularTaxaAutomatica();
    } else {
        painel.style.display = "none";
        document.getElementById('taxaCartaoInp').value = "0,00";
    }
}

function calcularTaxaAutomatica() {
    const painel = document.getElementById('detalhesCartao');
    if (painel.style.display === "none") return; 

    const valorTotalStr = document.getElementById('vParticularInp').value;
    const valorTotal = formatarParaCalculo(valorTotalStr);
    
    if (valorTotal <= 0) {
        document.getElementById('taxaCartaoInp').value = "0,00";
        return;
    }

    const ehDebito = document.getElementById('cartaoDebito').checked;
    const selectParcelas = document.getElementById('numParcelas');
    
    let taxaFinal = 0;
    const taxaDebito = 0.015;      // 1.5%
    const taxaCreditoBase = 0.03;  // 3%
    const taxaPorParcela = 0.01;   // +1% por parcela

    if (ehDebito) {
        selectParcelas.value = "1";
        selectParcelas.disabled = true;
        document.getElementById('divParcelas').style.opacity = '0.4';
        taxaFinal = valorTotal * taxaDebito;
    } else {
        selectParcelas.disabled = false;
        document.getElementById('divParcelas').style.opacity = '1';
        
        const parcelas = parseInt(selectParcelas.value);
        let percentual = taxaCreditoBase;
        if (parcelas > 1) {
            percentual += (parcelas - 1) * taxaPorParcela;
        }
        taxaFinal = valorTotal * percentual;
    }

    document.getElementById('taxaCartaoInp').value = taxaFinal.toLocaleString('pt-BR', {minimumFractionDigits: 2, maximumFractionDigits: 2});
}



