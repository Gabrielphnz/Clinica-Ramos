<script>
// ==========================================
// 1. VARIÁVEIS GLOBAIS VITAIS (BLINDADAS)
// ==========================================
var usuarioLogado = null; 
var dadosLocais = [];     
var listaTodosPacientes = []; 
var estoqueCompletoCache = [];
var listaDoutoresGlobal = [];
var datalistProdutosGlobal = '';
var datalistCategoriasGlobal = '';
var basePacientesCRM = [];

// ==========================================
// 1. INICIALIZAÇÃO BLINDADA DO SISTEMA
// ==========================================
// O Apps Script roda este script assim que o HTML termina de carregar.
// Escondemos o ERP proativamente.
document.getElementById("erp-app").style.display = "none";
document.getElementById("telaLogin").style.display = "flex";

// Esta função agora é a primeira a ser chamada, de forma agressiva.
(function iniciarSessaoSegura() {
  try {
    const salvo = localStorage.getItem('usuarioRamos');
    // Validação rígida: o cache tem que existir, ser texto, e ter estrutura de JSON.
    if (salvo && typeof salvo === 'string' && salvo.includes('success')) {
      const userTemp = JSON.parse(salvo);
      if (userTemp && userTemp.success) {
        usuarioLogado = userTemp;
        document.getElementById("telaLogin").style.display = "none";
        document.getElementById("erp-app").style.display = "block";
        inicializarSistema(); // Só puxa os dados se o usuário for válido
        return; // Sai da função, login funcionou.
      }
    }
  } catch (e) {
    console.error("Falha ao restaurar sessão:", e);
  }
  
  // Se caiu aqui (por erro ou falta de cache), a limpeza é compulsória.
  localStorage.removeItem('usuarioRamos');
  document.getElementById("telaLogin").style.display = "flex";
  document.getElementById("erp-app").style.display = "none";
})();

// ==========================================
// 2. FUNÇÕES DE AUTENTICAÇÃO
// ==========================================
function fazerLogin() {
  const user = document.getElementById("userLogin").value;
  const pass = document.getElementById("userPass").value;
  const btn = document.getElementById("btnLogin");
  const msg = document.getElementById("msgErroLogin");
  
  if (!user || !pass) { 
    msg.innerText = "❌ Digite seu usuário e senha.";
    msg.style.display = "block"; 
    return; 
  }

  // Trava o botão para não enviar requisições repetidas
  btn.disabled = true; 
  btn.innerText = "AUTENTICANDO..."; 
  msg.style.display = "none";
  
  google.script.run
    .withSuccessHandler(function(res) {
      if (res && res.success) {
        // Sucesso: Salva e inicia
        usuarioLogado = res; 
        try {
          localStorage.setItem('usuarioRamos', JSON.stringify(res));
        } catch (storageError) {
           console.warn("Navegador bloqueou o cache. O login funciona, mas não será lembrado.", storageError);
        }
        
        document.getElementById("telaLogin").style.display = "none";
        document.getElementById("erp-app").style.display = "block";
        inicializarSistema(); 
        mostrarNotificacao("Bem-vindo(a), " + res.nome + "!", "sucesso");
      } else {
        // Falha de credencial
        msg.innerText = "❌ " + (res.msg || "Credenciais incorretas."); 
        msg.style.display = "block";
        btn.disabled = false; 
        btn.innerText = "ENTRAR";
      }
    })
    .withFailureHandler(function(err) {
      // Falha de servidor
      msg.innerText = "❌ Erro de comunicação com o servidor."; 
      msg.style.display = "block"; 
      btn.disabled = false; 
      btn.innerText = "ENTRAR";
    })
    .validarLogin(user, pass);
}
function fazerLogout() {
  usuarioLogado = null;
  localStorage.removeItem('usuarioRamos');
  
  const loginInput = document.getElementById("userLogin");
  const passInput = document.getElementById("userPass");
  const msgDiv = document.getElementById("msgErroLogin");
  const btn = document.getElementById("btnLogin");
  
  if (loginInput) loginInput.value = "";
  if (passInput) passInput.value = "";
  if (msgDiv) {
    msgDiv.innerText = "";
    msgDiv.style.display = "none";
  }
  if (btn) {
    btn.disabled = false;
    btn.innerText = "ENTRAR";
  }
  
  document.getElementById("erp-app").style.display = "none";
  const telaLogin = document.getElementById("telaLogin");
  if (telaLogin) telaLogin.style.display = "flex";
  
  mostrarNotificacao("Você saiu do sistema com segurança.", "sucesso");
}

function inicializarSistema() {
  // 1. Puxa as listas suspensas antigas
  google.script.run.withSuccessHandler(function(listas) {
      const popular = (id, arr) => {
        const el = document.getElementById(id);
        if (el && arr) {
          el.innerHTML = '<option value="">Selecione...</option>';
          arr.forEach(i => { 
            let o = document.createElement("option"); 
            o.value = i; o.text = i; el.add(o); 
          });
        }
      };
      popular("sel_doutor", listas.doutores);
      popular("sel_plano", listas.planos);
      popular("sel_proc", listas.procedimentos);
      popular("sel_pag", listas.pagamentos);
      popular("sel_convenio_paciente", listas.planos);
      popular("selFiltroDoutorAgenda", listas.doutores);
      popular("ag_doutor", listas.doutores);
      popular("ag_procedimento", listas.procedimentos);
      
      listaDoutoresGlobal = listas.doutores || []; 
      
      if (listas.pacientes) listaTodosPacientes = listas.pacientes;
  }).getListasDropdown();

  // 2. [NOVO] Puxa a nova base de pacientes do CRM silenciosamente
  google.script.run.withSuccessHandler(function(res) {
      basePacientesCRM = res || [];
      console.log("SUCESSO: Foram carregados " + basePacientesCRM.length + " pacientes do CRM.");
  }).getPacientesCRM();

  // 3. Atualiza a tabela do ERP na tela
  atualizarTabelaGlobal();
}

// ==========================================
// 3. CONTROLE DE PERMISSÕES
// ==========================================
function configurarAcessoBotoes() {
  if (!usuarioLogado) return;

  if (usuarioLogado.nivel === "RECEPCAO") {
    const cardsFinanceiros = document.getElementById("cardsResumoFinanceiro");
    if (cardsFinanceiros) cardsFinanceiros.style.display = "none";

    if ($.fn.DataTable.isDataTable('#minhaTabela')) {
      const tabela = $('#minhaTabela').DataTable();
      tabela.column(5).visible(false); 
      tabela.column(6).visible(false); 
      tabela.column(7).visible(false); 
    }
  }

  if (usuarioLogado.nivel !== "ADMIN") {
    const permissoes = (usuarioLogado.permissoes || "").toUpperCase();

    const btnRelatorio = document.querySelector('[onclick="gerarRelatorio()"]');
    const btnHolerite = document.querySelector('[onclick="gerarHolerite()"]');
    const btnResultado = document.querySelector('[onclick="gerarResultado()"]');
    const btnConfig = document.querySelector('[onclick="abrirConfiguracao()"]');
    const btnDashboard = document.querySelector('[onclick="abrirDashboard()"]');

    if (btnRelatorio) btnRelatorio.style.setProperty("display", "none", "important");
    if (btnHolerite) btnHolerite.style.setProperty("display", "none", "important");
    if (btnResultado) btnResultado.style.setProperty("display", "none", "important");
    if (btnConfig) btnConfig.style.setProperty("display", "none", "important");
    if (btnDashboard) btnDashboard.style.setProperty("display", "none", "important");

    if (permissoes.includes("RELATORIO") && btnRelatorio) btnRelatorio.style.display = "inline-block";
    if (permissoes.includes("HOLERITE") && btnHolerite) btnHolerite.style.display = "inline-block";
    if (permissoes.includes("RESULTADO") && btnResultado) btnResultado.style.display = "inline-block";
    if (permissoes.includes("CONFIG") && btnConfig) btnConfig.style.display = "inline-block";
    if (permissoes.includes("DASHBOARD") && btnDashboard) btnDashboard.style.display = "inline-block";
  }
}

// ==========================================
// 4. EXIBIÇÃO DA TABELA DO ERP PRINCIPAL
// ==========================================
function atualizarTabelaGlobal(silencioso = false) {
  if (!silencioso) {
    $("#conteudo").hide(); 
    $("#loader").show();
  } else {
    mostrarNotificacao("🔄 Atualizando tabela...", "info");
  }
  
  google.script.run
    .withFailureHandler(err => {
      $("#loader").hide();
      mostrarNotificacao("❌ Erro ao carregar dados", "erro");
    })
    .withSuccessHandler(exibirTabela)
    .getDadosTabelaERP();
}

function exibirTabela(dados) {
  if (!dados || dados.length === 0) {
    $("#conteudo").html('<div class="alert alert-info mt-3">Nenhum registro encontrado.</div>');
    $("#loader").hide(); $("#conteudo").show(); 
    return;
  }
  
  dadosLocais = dados; 
  listaTodosPacientes = [...new Set(dadosLocais.map(d => d.paciente))].filter(Boolean).sort();

  const datasOrdenadas = [...new Set(dadosLocais.map(r => r.data))]
    .filter(d => d && d.includes('/')) 
    .sort((a, b) => {
      const [diaA, mesA, anoA] = a.split('/');
      const [diaB, mesB, anoB] = b.split('/');
      return new Date(anoB, mesB-1, diaB) - new Date(anoA, mesA-1, diaA);
    });
    
  const dataMaisRecente = datasOrdenadas.length > 0 ? datasOrdenadas[0] : new Date().toLocaleDateString('pt-BR');
  const dadosHoje = dadosLocais.filter(r => r.data === dataMaisRecente);


// SÓ DESENHA A ESTRUTURA SE ELA NÃO EXISTIR
  if (document.getElementById("minhaTabela") === null) {
      let htmlStructure = `
        <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3 p-2 bg-white rounded-3 shadow-sm border">
            
            <div class="d-flex gap-2">
                <div class="dropdown">
                    <button class="btn btn-outline-secondary btn-sm dropdown-toggle fw-bold d-flex align-items-center gap-1" type="button" data-bs-toggle="dropdown">
                        <span class="material-icons" style="font-size: 16px;">bar_chart</span> RELATÓRIOS
                    </button>
                    <ul class="dropdown-menu shadow border-0" style="border-radius: 12px; font-size: 14px;">
                        <li><button class="dropdown-item py-2" type="button" onclick="gerarRelatorio()"><span class="material-icons align-middle me-2 text-muted" style="font-size: 18px;">description</span> Relatório Geral</button></li>
                        <li><button class="dropdown-item py-2" type="button" onclick="gerarHolerite()"><span class="material-icons align-middle me-2 text-muted" style="font-size: 18px;">receipt_long</span> Holerite</button></li>
                        <li><button class="dropdown-item py-2" type="button" onclick="gerarResultado()"><span class="material-icons align-middle me-2 text-muted" style="font-size: 18px;">insights</span> Resultado da Clínica</button></li>
                    </ul>
                </div>

                <div class="dropdown">
                    <button class="btn btn-outline-primary btn-sm dropdown-toggle fw-bold d-flex align-items-center gap-1" type="button" data-bs-toggle="dropdown">
                        <span class="material-icons" style="font-size: 16px;">app_registration</span> GERENCIAMENTO
                    </button>
                    <ul class="dropdown-menu shadow border-0" style="border-radius: 12px; font-size: 14px;">
                        <li><button class="dropdown-item py-2" type="button" onclick="abrirModalRecall()"><span class="material-icons align-middle me-2 text-warning" style="font-size: 18px;">update</span> Retornos (Recall)</button></li>
                        <li><button class="dropdown-item py-2" type="button" onclick="abrirAlmoxarifado()"><span class="material-icons align-middle me-2 text-success" style="font-size: 18px;">inventory_2</span> Estoque</button></li>
                        <li><button class="dropdown-item py-2" type="button" onclick="abrirGerenciamentoLab()"><span class="material-icons align-middle me-2 text-info" style="font-size: 18px;">biotech</span> Laboratório</button></li>
                        <li><hr class="dropdown-divider"></li>
                        <li><button class="dropdown-item py-2" type="button" onclick="abrirConfiguracao()"><span class="material-icons align-middle me-2 text-secondary" style="font-size: 18px;">settings</span> Configurações</button></li>
                    </ul>
                </div>
            </div>

            <div class="d-flex gap-3 align-items-center">
                <div class="position-relative mt-1" onclick="toggleNotificacoes()" style="cursor: pointer;" title="Notificações">
                  <span class="material-icons text-secondary" style="font-size: 28px;">notifications</span>
                  <span id="badgeNotificacao" class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger border border-white" style="display: none; font-size: 10px;">0</span>
                </div>
                
                <div style="border-left: 1px solid #dee2e6; height: 30px;"></div>

                <button class="btn btn-info btn-sm text-white d-flex align-items-center shadow-sm" onclick="abrirDashboard()" title="Painel Gráfico">
                    <span class="material-icons" style="font-size:20px;">pie_chart</span>
                </button>
                
                <button class="btn btn-success btn-sm fw-bold shadow-sm d-flex align-items-center gap-1" onclick="abrirModalPaciente()">
                    <span class="material-icons" style="font-size: 18px;">person_add</span> PACIENTE
                </button>

                <button class="btn btn-primary btn-sm fw-bold shadow-sm d-flex align-items-center gap-1" onclick="abrirFormulario()">
                    <span class="material-icons" style="font-size: 18px;">add_circle</span> LANÇAMENTO
                </button>
            </div>
        </div>
        
        <div class="alert alert-info py-3 mb-3" id="avisoDataTabela" role="alert"></div>
        <table id="minhaTabela" class="table table-striped table-hover w-100"></table>
        
        <div class="row g-3 mt-3 mb-2" id="cardsResumoFinanceiro">
            <div class="col-md-6"><div class="card bg-success shadow-sm"><div class="card-body p-4 text-center"><h6 class="mb-2 text-white" id="titPartDia">💰 TOTAL PARTICULAR</h6><h4 class="mb-0 text-white" id="partDia">R$ 0,00</h4></div></div></div>
            <div class="col-md-6"><div class="card bg-primary shadow-sm"><div class="card-body p-4 text-center"><h6 class="mb-2 text-white" id="titPlanoDia">📋 TOTAL PLANO</h6><h4 class="mb-0 text-white" id="planoDia">R$ 0,00</h4></div></div></div>
        </div>
        <div id="cardsFiltrados" style="display: none;" class="row g-3 mt-2 mb-3">
            <div class="col-md-6"><div class="card bg-success shadow-sm" style="opacity: 0.85;"><div class="card-body p-4 text-center"><h6 class="mb-2 text-white">💰 PARTICULAR - FILTRADO</h6><h4 class="mb-0 text-white" id="resumoPartHtml">R$ 0,00</h4></div></div></div>
            <div class="col-md-6"><div class="card bg-primary shadow-sm" style="opacity: 0.85;"><div class="card-body p-4 text-center"><h6 class="mb-2 text-white">📋 PLANO - FILTRADO</h6><h4 class="mb-0 text-white" id="resumoPlanoHtml">R$ 0,00</h4></div></div></div>
        </div>
      `;
      $("#conteudo").html(htmlStructure);
  }

  // Atualiza os textos dos cards de forma silenciosa
  $("#avisoDataTabela").html(`<small>📅 Última data com registros: <strong>${dataMaisRecente}</strong> (${dadosHoje.length} atendimento${dadosHoje.length !== 1 ? 's' : ''})</small>`);
  $("#titPartDia").text(`💰 TOTAL PARTICULAR - ${dataMaisRecente}`);
  $("#titPlanoDia").text(`📋 TOTAL PLANO - ${dataMaisRecente}`);
  
  let partHoje = 0, planoHoje = 0;
  dadosHoje.forEach(r => { partHoje += Number(r.particular) || 0; planoHoje += Number(r.vplano) || 0; });
  const formataReal = (v) => v.toLocaleString('pt-BR', { style: 'currency', currency: 'BRL' });
  $("#partDia").text(formataReal(partHoje)); $("#planoDia").text(formataReal(planoHoje));
  
  const dadosExibicao = [...dadosLocais].sort((a, b) => {
    if(!a.data || !a.data.includes('/')) return 1; 
    if(!b.data || !b.data.includes('/')) return -1;
    const [diaA, mesA, anoA] = a.data.split('/'); const [diaB, mesB, anoB] = b.data.split('/');
    const dataA = new Date(anoA, mesA-1, diaA).getTime(); const dataB = new Date(anoB, mesB-1, diaB).getTime();
    if (dataB === dataA) return (b.id || 0) - (a.id || 0);
    return dataB - dataA;
  });
  
  const dataSet = dadosExibicao.map(r => {
    let obsHtml = '';
    if (r.obs && r.obs.toString().trim() !== '') {
      let textoSeguro = encodeURIComponent(r.obs.toString());
      obsHtml = '<span class="badge-obs" data-obs="' + textoSeguro + '" onclick="verObs(this)">💬 Ler OBS</span>';
