function checarEnterLote(event, tipo) {
  if (event.key === 'Enter') {
    event.preventDefault(); // Evita que o formulário recarregue a página
    adicionarLinhaLote(tipo); // Cria a linha nova

    // Foca automaticamente no campo "Produto" da linha que acabou de ser criada
