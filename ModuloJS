function filtrarDocsProntuario(termo) {
  const busca = termo.toLowerCase().normalize("NFD").replace(/[\u0300-\u036f]/g, "");
  const linhas = document.querySelectorAll("#tabelaDocsProntuario .linha-documento");
  
  linhas.forEach(linha => {
    const textoLinha = linha.innerText.toLowerCase().normalize("NFD").replace(/[\u0300-\u036f]/g, "");
    if (textoLinha.includes(busca)) {
      linha.style.display = ""; // Mostra
    } else {
      linha.style.display = "none"; // Esconde
    }
  });
}

