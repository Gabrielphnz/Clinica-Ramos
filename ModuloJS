  }
  
  else if (tipo === 'ORCAMENTO') {
      let linhasTabela = ''; let total = 0;
      if (itensOrcamentoAtuais.length === 0) { btn.disabled = false; btn.innerText = "GERAR PDF DO ORÇAMENTO"; return mostrarNotificacao("Adicione procedimentos no orçamento!", "erro"); }
