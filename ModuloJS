function salvarTrabalhoLab() {
  const btn = event.target;
  const hiddenIdEl = document.getElementById('lab_id_edicao');
  
  const dados = {
    idEdicao: hiddenIdEl ? hiddenIdEl.value : null,
    paciente: document.getElementById('lab_paciente_nome').value,
    proc: document.getElementById('lab_procedimento').value,
    nomeLab: document.getElementById('lab_nome_empresa').value,
    prazo: document.getElementById('lab_prazo_dias').value
  };

  if (!dados.nomeLab || !dados.prazo) return mostrarNotificacao("Preencha o laboratório e prazo!", "erro");

  btn.disabled = true; btn.innerText = "SALVANDO...";
  google.script.run.withSuccessHandler(function(res) {
    mostrarNotificacao("✅ " + res.msg, "sucesso");
    bootstrap.Modal.getInstance(document.getElementById('modalCadastroLab')).hide();
    btn.disabled = false; btn.innerText = "CADASTRAR TRABALHO";
    if (hiddenIdEl) hiddenIdEl.value = ""; // Limpa a memória de edição
    
    carregarNotificacoes(); // Atualiza Sininho
    if (document.getElementById('modalGerenciamentoLab')) carregarTabelaLab(); // Atualiza a Tabela Grande se estiver aberta
    
  }).withFailureHandler(function(err) {
    mostrarNotificacao("❌ Erro: " + err, "erro");
    btn.disabled = false; btn.innerText = "CADASTRAR TRABALHO";
  }).apiSalvarLaboratorio(dados);
}

function finalizarAlertaLab(idRef) {
  if(!confirm("A prótese/trabalho realmente chegou na clínica?\nO alerta será encerrado.")) return;

  mostrarNotificacao("⏳ Baixando alerta...", "info");
  google.script.run.withSuccessHandler(function() {
    mostrarNotificacao("✅ Trabalho marcado como recebido!", "sucesso");
    carregarNotificacoes(); // Recarrega o sininho na mesma hora
  }).apiFinalizarLaboratorio(idRef);
}

