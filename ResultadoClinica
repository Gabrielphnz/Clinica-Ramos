<!DOCTYPE html>
<html>
<head>
  <base target="_top">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.2.3/dist/css/bootstrap.min.css">
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap');

    :root {
      --primary: #4318FF;
      --secondary: #F4F7FE;
      --text-main: #2B3674;
      --text-muted: #A3AED0;
      --success: #05CD99;
      --warning: #FFCE20;
      --danger: #EE5D50;
      --info: #00B5E2;
      --bg-card: #FFFFFF;
      --card-shadow: 0px 18px 40px rgba(112, 144, 176, 0.08);
    }

    body { 
      background-color: var(--secondary); 
      font-family: 'Plus Jakarta Sans', sans-serif;
      color: var(--text-main);
      padding: 15px 25px;
      font-size: 13px;
    }

    ::-webkit-scrollbar { width: 6px; }
    ::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 10px; }

    /* CABEÇALHO PREMIUM */
    .header-slim {
      display: flex; justify-content: space-between; align-items: center;
      background: white; padding: 12px 25px; border-radius: 16px;
      box-shadow: var(--card-shadow); margin-bottom: 15px;
    }
    .header-slim h2 { font-weight: 800; font-size: 18px; margin: 0; letter-spacing: -0.5px; }
    
    .mes-input {
      border: 2px solid #E9EDF7; border-radius: 10px; padding: 6px 12px;
      font-size: 13px; font-weight: 700; color: var(--primary);
      width: 120px; text-align: center; outline: none;
    }
    .mes-input:focus { border-color: var(--primary); }

    .btn-analisar {
      background: linear-gradient(135deg, var(--primary) 0%, #868CFF 100%);
      color: white; border: none; padding: 8px 18px; border-radius: 10px;
      font-weight: 700; transition: 0.3s; box-shadow: 0 4px 12px rgba(67, 24, 255, 0.2);
    }
    .btn-analisar:hover { transform: translateY(-2px); box-shadow: 0 6px 15px rgba(67, 24, 255, 0.3); }

    .card-mini {
      background: var(--bg-card); border-radius: 16px; padding: 15px;
      box-shadow: var(--card-shadow); height: 100%;
    }
    .card-mini h6 { color: var(--text-muted); font-size: 11px; font-weight: 700; text-transform: uppercase; margin-bottom: 5px; }
    .card-mini h3 { color: var(--text-main); font-size: 20px; font-weight: 800; margin: 0; }
    
    /* BARRA DE DISTRIBUIÇÃO */
    .finance-split { display: flex; height: 12px; border-radius: 6px; overflow: hidden; margin: 10px 0; }
    .split-lucro { background: var(--success); transition: width 1s; }
    .split-repasse { background: var(--info); transition: width 1s; }
    .split-lab { background: var(--danger); transition: width 1s; }

    /* MATRIZ SLIM */
    .table-matrix-wrapper { max-height: 280px; overflow-y: auto; }
    .table-matrix { width: 100%; font-size: 12px; }
    .table-matrix th { color: var(--text-muted); font-size: 10px; font-weight: 700; text-transform: uppercase; padding: 10px; border-bottom: 2px solid #F4F7FE; text-align: right; position: sticky; top: 0; background: white;}
    .table-matrix th:first-child { text-align: left; }
    .table-matrix td { padding: 8px 10px; border-bottom: 1px solid #F4F7FE; font-weight: 600; text-align: right; }
    .table-matrix td:first-child { text-align: left; }
    
    .badge-status { padding: 3px 6px; border-radius: 5px; font-size: 10px; font-weight: 800; }
    
    /* BARRINHAS LÚDICAS */
    .bar-item { margin-bottom: 10px; }
    .bar-info { display: flex; justify-content: space-between; font-size: 11px; font-weight: 700; margin-bottom: 2px; }
    .bar-track { width: 100%; height: 5px; background: #E9EDF7; border-radius: 10px; overflow: hidden; }
    .bar-fill { height: 100%; border-radius: 10px; transition: 1s ease-out; }

    .chart-container { position: relative; height: 210px; width: 100%; }
    #loader { display: none; text-align: center; padding: 30px; font-weight: 700; color: var(--primary); }
  </style>
</head>
<body>

  <div class="header-slim">
    <h2>🎯 Gestão de Resultados Clínica</h2>
    <div class="d-flex gap-2 align-items-center">
      <input type="text" id="mesInput" class="mes-input" placeholder="MM/AAAA" maxlength="7" oninput="mascaraMes(this)">
      <button class="btn-analisar" onclick="carregarResultados()">PROCESSAR</button>
    </div>
  </div>

  <div id="loader">Processando números...</div>

  <div id="conteudoDash" style="display: none;">
    
    <div class="row g-3 mb-3">
      <div class="col-md-3"><div class="card-mini"><h6>Faturamento Bruto</h6><h3 id="kpiBruto">R$ 0</h3></div></div>
      <div class="col-md-3"><div class="card-mini" style="border-bottom: 3px solid var(--success);"><h6>Lucro Real Clínica</h6><h3 id="kpiLiquido" style="color: var(--success);">R$ 0</h3></div></div>
      <div class="col-md-3"><div class="card-mini"><h6>Margem Líquida</h6><h3 id="kpiMargem">0%</h3></div></div>
      <div class="col-md-3"><div class="card-mini"><h6>Ticket por Paciente</h6><h3 id="kpiTicket">R$ 0</h3></div></div>
    </div>

    <div class="row g-3 mb-3">
      <div class="col-12">
        <div class="card-mini">
          <h6>🍕 Distribuição da Receita (%)</h6>
          <div class="finance-split">
            <div id="barLucro" class="split-lucro" style="width: 0%;"></div>
            <div id="barRepasse" class="split-repasse" style="width: 0%;"></div>
            <div id="barLab" class="split-lab" style="width: 0%;"></div>
          </div>
          <div class="d-flex justify-content-between font-monospace" style="font-size: 10px; color: var(--text-muted); font-weight: 700;">
            <div id="lblLucro">LUCRO: 0%</div><div id="lblRepasse">REPASSE: 0%</div><div id="lblLab">LAB: 0%</div>
          </div>
        </div>
      </div>
    </div>

    <div class="row g-3">
      <div class="col-md-8">
        <div class="card-mini mb-3">
          <h6>📊 Matriz de Eficiência (Top 6 Doutores)</h6>
          <div class="table-matrix-wrapper">
            <table class="table-matrix">
              <thead>
                <tr><th>Doutor</th><th>Bruto</th><th>Repasse</th><th>Lab</th><th>Lucro</th><th>Margem</th></tr>
              </thead>
              <tbody id="tbodyMatriz"></tbody>
            </table>
          </div>
        </div>
        
        <div class="card-mini">
          <h6>📈 Análise de Equilíbrio: Repasse vs Lucro</h6>
          <div class="chart-container">
            <canvas id="chartGestao"></canvas>
          </div>
        </div>
      </div>

      <div class="col-md-4">
        <div class="card-mini mb-3">
          <h6>💳 Mix de Recebimentos</h6>
          <div id="areaPagamentos"></div>
        </div>

        <div class="card-mini">
          <h6>🦷 Top 15 Procedimentos Lucrativos</h6>
          <div id="areaProcedimentos" style="max-height: 460px; overflow-y: auto; padding-right: 5px;"></div>
        </div>
      </div>
    </div>
  </div>

  <script>
    let chartGestao = null;
    const formataMoeda = (v) => Number(v).toLocaleString('pt-BR', {style: 'currency', currency: 'BRL', minimumFractionDigits: 0});
    const formataPct = (v) => (Number(v)).toFixed(1) + '%';

    // MÁSCARA AUTOMÁTICA DE DATA (MM/AAAA)
    function mascaraMes(input) {
      let v = input.value.replace(/\D/g, '').slice(0, 6);
      if (v.length >= 5) input.value = v.replace(/^(\d{2})(\d{0,4}).*/, "$1/$2");
      else if (v.length >= 3) input.value = v.replace(/^(\d{2})(\d{0,2}).*/, "$1/$2");
      else input.value = v;
    }

    // AUTO-PREENCHIMENTO DO MÊS ATUAL AO CARREGAR
    window.onload = function() {
      const hoje = new Date();
      const m = String(hoje.getMonth() + 1).padStart(2, '0');
      const a = hoje.getFullYear();
      document.getElementById('mesInput').value = `${m}/${a}`;
    };

    function carregarResultados() {
      const mes = document.getElementById('mesInput').value;
      if(mes.length < 7) return alert("Digite o mês corretamente (Ex: 03/2026)");
      document.getElementById('conteudoDash').style.display = 'none';
      document.getElementById('loader').style.display = 'block';
      google.script.run.withSuccessHandler(montarTela).getDadosTabelaERP();
    }

    function montarTela(dadosBrutos) {
      document.getElementById('loader').style.display = 'none';
      document.getElementById('conteudoDash').style.display = 'block';
      const mesAlvo = document.getElementById('mesInput').value;
      
      const dadosFiltrados = dadosBrutos.filter(d => d.data && (d.data.split('/')[1] + '/' + d.data.split('/')[2]) === mesAlvo);

      if(dadosFiltrados.length === 0) {
        alert("Sem dados para este período.");
        return;
      }

      let totalBruto = 0, totalLiquido = 0, totalRepasse = 0, totalLab = 0;
      let pacientesUnicos = new Set(), formPagtoMap = {}, procMap = {}, doutoresMap = {};

      dadosFiltrados.forEach(d => {
        let bruto = (d.particular || 0) + (d.vplano || 0);
        totalBruto += bruto; 
        totalLiquido += (d.lucroClinica || 0); 
        totalRepasse += (d.parteDentista || 0); 
        totalLab += (d.vlab || 0);
        if (d.paciente) pacientesUnicos.add(d.paciente);

        let pg = d.pagamento || 'Outros';
        formPagtoMap[pg] = (formPagtoMap[pg] || 0) + bruto;

        let proc = d.procedimento || '-';
        procMap[proc] = (procMap[proc] || 0) + (d.lucroClinica || 0);

        let dr = d.doutor || 'Sem Nome';
        if (!doutoresMap[dr]) doutoresMap[dr] = { bruto: 0, repasse: 0, lab: 0, liquido: 0 };
        doutoresMap[dr].bruto += bruto; 
        doutoresMap[dr].repasse += (d.parteDentista || 0);
        doutoresMap[dr].lab += (d.vlab || 0); 
        doutoresMap[dr].liquido += (d.lucroClinica || 0);
      });

      // Atualiza KPIs
      document.getElementById('kpiBruto').innerText = formataMoeda(totalBruto);
      document.getElementById('kpiLiquido').innerText = formataMoeda(totalLiquido);
      document.getElementById('kpiMargem').innerText = totalBruto > 0 ? formataPct((totalLiquido/totalBruto)*100) : '0%';
      document.getElementById('kpiTicket').innerText = formataMoeda(pacientesUnicos.size > 0 ? totalBruto / pacientesUnicos.size : 0);

      // Anima Barra de Distribuição
      setTimeout(() => {
        document.getElementById('barLucro').style.width = (totalLiquido/totalBruto*100) + '%';
        document.getElementById('barRepasse').style.width = (totalRepasse/totalBruto*100) + '%';
        document.getElementById('barLab').style.width = (totalLab/totalBruto*100) + '%';
        document.getElementById('lblLucro').innerText = 'LUCRO: ' + formataPct(totalLiquido/totalBruto*100);
        document.getElementById('lblRepasse').innerText = 'REPASSE: ' + formataPct(totalRepasse/totalBruto*100);
        document.getElementById('lblLab').innerText = 'LAB: ' + formataPct(totalLab/totalBruto*100);
      }, 100);

      // Tabela Matriz
      let htmlMatriz = "";
      let drArray = Object.entries(doutoresMap).sort((a,b) => b[1].liquido - a[1].liquido).slice(0,6);
      drArray.forEach(([n, i]) => {
        let mrg = i.bruto > 0 ? (i.liquido/i.bruto)*100 : 0;
        htmlMatriz += `<tr><td>${n}</td><td>${formataMoeda(i.bruto)}</td><td>${formataMoeda(i.repasse)}</td><td>${formataMoeda(i.lab)}</td><td style="color:var(--success)">${formataMoeda(i.liquido)}</td><td><span class="badge-status" style="background:${mrg>30?'#E6FBF5':'#FDE8E6'};color:${mrg>30?'#05CD99':'#EE5D50'}">${formataPct(mrg)}</span></td></tr>`;
      });
      document.getElementById('tbodyMatriz').innerHTML = htmlMatriz;

      // Mix Pagamentos
      let htmlPagtos = "";
      Object.entries(formPagtoMap).sort((a,b) => b[1]-a[1]).forEach(([n, v]) => {
        let pct = (v/totalBruto)*100;
        htmlPagtos += `<div class="bar-item"><div class="bar-info"><span>${n}</span><span>${pct.toFixed(0)}%</span></div><div class="bar-track"><div class="bar-fill" style="width:${pct}%;background:var(--info)"></div></div></div>`;
      });
      document.getElementById('areaPagamentos').innerHTML = htmlPagtos;

      // Top 15 Procedimentos
      let htmlProcs = "";
      let pArray = Object.entries(procMap).sort((a,b) => b[1]-a[1]).slice(0, 15);
      let maxP = pArray.length > 0 ? pArray[0][1] : 1;
      pArray.forEach(([n, v]) => {
        let pct = (v/maxP)*100;
        htmlProcs += `<div class="bar-item"><div class="bar-info"><span>${n}</span><span>${formataMoeda(v)}</span></div><div class="bar-track"><div class="bar-fill" style="width:${pct}%;background:var(--success)"></div></div></div>`;
      });
      document.getElementById('areaProcedimentos').innerHTML = htmlProcs;

      renderChartGestao(drArray);
    }

    function renderChartGestao(drArray) {
      if(chartGestao) chartGestao.destroy();
      const ctx = document.getElementById('chartGestao').getContext('2d');
      chartGestao = new Chart(ctx, {
        type: 'bar',
        data: {
          labels: drArray.map(d => d[0]),
          datasets: [
            { label: 'Lucro Clínica', data: drArray.map(d => d[1].liquido), backgroundColor: '#05CD99', borderRadius: 5 },
            { label: 'Repasse Doutor', data: drArray.map(d => d[1].repasse), backgroundColor: '#4318FF', borderRadius: 5 }
          ]
        },
        options: {
          responsive: true, maintainAspectRatio: false,
          scales: { 
            x: { grid: { display: false } }, 
            y: { ticks: { font: { size: 10 } } }
          },
          plugins: { 
            legend: { position: 'bottom', labels: { boxWidth: 12, font: { size: 10, family: 'Plus Jakarta Sans' } } } 
          }
        }
      });
    }
  </script>
</body>
</html>
